# ═══ DATABASE (self-hosted PostgreSQL in Docker) ═══
DATABASE_URL=postgresql://horeca1:horeca1_dev@localhost:5432/horeca1

# ═══ AUTH (Auth.js v5) ═══
AUTH_SECRET=generate-a-random-32-char-string-here
AUTH_URL=http://localhost:3000

# ═══ REDIS (BullMQ + cache) ═══
REDIS_URL=redis://localhost:6379

# ═══ PAYMENTS (Razorpay) ═══
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# ═══ IMAGES (ImageKit) ═══
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/horeca1

# ═══ SMS/OTP/WhatsApp (MSG91) ═══
MSG91_AUTH_KEY=xxx
MSG91_SENDER_ID=HCXGBL
MSG91_TEMPLATE_ID=xxx          # OTP template (phone login/register)
# WhatsApp — add once your WhatsApp Business number is approved in MSG91 dashboard:
MSG91_WHATSAPP_NUMBER=91XXXXXXXXXX
MSG91_WHATSAPP_TEMPLATE_ID=xxx

# ═══ EMAIL (Resend) ═══
RESEND_API_KEY=re_xxx
# Without a domain: keep as onboarding@resend.dev (Resend test domain — only delivers to your own verified email)
# With a domain: set to noreply@yourdomain.com after verifying domain in Resend dashboard
EMAIL_FROM=HoReCa Hub <onboarding@resend.dev>

# ═══ MONITORING (Sentry) ═══
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ═══ GOOGLE MAPS (existing) ═══
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=xxx

# ═══ EMBEDDINGS (Brand mapping AI assist — provider-agnostic) ═══
# Pick ONE provider. The app picks the right class based on EMBEDDING_PROVIDER.
# If the provider call fails at runtime, brand mapper falls back to rule-based scoring (no crash).
EMBEDDING_PROVIDER=openai          # openai | deepseek | cohere | local

# OpenAI — text-embedding-3-small, 1536 dims, ~$0.02/M tokens
OPENAI_API_KEY=sk-xxx

# DeepSeek — OpenAI-compatible endpoint, model defaults to deepseek-embedding
DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding   # optional override

# Cohere — embed-multilingual-v3.0, 1024 dims (good for Hindi + English)
COHERE_API_KEY=xxx
# COHERE_EMBEDDING_MODEL=embed-multilingual-v3.0   # optional override

# Local sentence-transformers (or any HTTP service that accepts { texts } and returns { embeddings })
EMBEDDING_LOCAL_URL=http://localhost:8000/embed
EMBEDDING_LOCAL_DIMENSIONS=768

# ═══ MAPPING AI — LLM-as-judge for brand SKU mapping (alt path) ═══
# Different from EMBEDDING_PROVIDER above. When set, the brand mapper sends
# uncertain candidate pairs (rule score 0.55-0.95) to a chat model for a yes/no
# verdict. Slower than embeddings but works with chat-only providers.
# Leave unset to skip the AI step (rule-based + embeddings only).
MAPPING_AI_PROVIDER=openrouter

# OpenRouter — OpenAI-compatible router. Pick any chat model from openrouter.ai/models.
# google/gemini-2.0-flash-001 is fast + cheap (~$0.10/M tokens) and great at JSON.
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=google/gemini-2.0-flash-001
