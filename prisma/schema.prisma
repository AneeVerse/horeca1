generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══ AUTH.JS MODELS ═══════════════════════════════════
// Required by @auth/prisma-adapter for session management

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}


// ═══ USER ═════════════════════════════════════════════

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  phone         String?   @unique @db.VarChar(20)
  fullName      String    @default("") @map("full_name") @db.VarChar(255)
  image         String?   @db.VarChar(512)
  role          Role      @default(customer)
  pincode       String?   @db.VarChar(10)
  businessName  String?   @map("business_name") @db.VarChar(255)
  gstNumber     String?   @map("gst_number") @db.VarChar(20)
  isActive      Boolean   @default(true) @map("is_active")
  profileCompletedAt DateTime? @map("profile_completed_at") @db.Timestamptz
  // V2.2: human-readable HCID display, e.g. "HC-A4F2-9X3K". Generated at signup via src/lib/hcid.ts.
  hcidDisplay   String    @unique @map("hcid_display") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  accounts Account[]
  sessions Session[]

  linkedAccounts  LinkedAccount[] @relation("MyLinks")
  linkedBy        LinkedAccount[] @relation("LinkedToMe")

  vendors         Vendor[]
  brands          Brand[]
  carts           Cart[]   // V2.2: one cart per (businessAccountId, outletId)
  wallet          Wallet?
  orders          Order[]
  quickOrderLists QuickOrderList[]
  customerVendors CustomerVendor[]
  creditAccounts  CreditAccount[]
  notifications   Notification[]
  reviews         Review[]
  vendorCustomers VendorCustomer[] @relation("VendorCustomerUser")

  vendorMemberships VendorTeamMember[] @relation("VendorMemberships")
  vendorInvitesSent VendorTeamMember[] @relation("VendorInvites")
  brandMemberships  BrandTeamMember[]  @relation("BrandMemberships")
  brandInvitesSent  BrandTeamMember[]  @relation("BrandInvites")
  adminMembership   AdminTeamMember?   @relation("AdminMembership")
  adminInvitesSent  AdminTeamMember[]  @relation("AdminInvites")
  savedAddresses    SavedAddress[]
  returnRequests    ReturnRequest[] @relation("CustomerReturnRequests")
  pushSubscriptions PushSubscription[]

  // V2.2 — multi-account access
  accountMemberships BusinessAccountMember[] @relation("UserAccountMembership")
  accountInvitesSent BusinessAccountMember[] @relation("AccountInvites")
  userRoles          UserRole[]              @relation("UserRoles")

  // V2.2 Phase 1 — Salesman Commission
  salespersonProfile     Salesperson[]        @relation("UserSalespersonProfile")
  approvedAccruals       CommissionAccrual[]  @relation("CommissionApprover")

  // V2.2 Phase 4 — Pricelist assignments targeting this user
  priceListAssignments   PriceListAssignment[] @relation("PriceListAssignmentUser")

  @@index([email])
  @@index([phone])
  @@index([pincode])
  @@index([role])
  @@map("users")
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum Role {
  customer
  vendor
  admin
  brand
}

enum TeamRole {
  owner
  manager
  editor
  viewer
}

// ═══ LINKED ACCOUNTS (multi-account switcher) ════════

model LinkedAccount {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  linkedUserId String   @map("linked_user_id") @db.Uuid
  switchToken  String   @unique @default(uuid()) @map("switch_token") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User @relation("MyLinks", fields: [userId], references: [id], onDelete: Cascade)
  linkedUser User @relation("LinkedToMe", fields: [linkedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, linkedUserId])
  @@index([userId])
  @@index([switchToken])
  @@map("linked_accounts")
}

// ═══ VENDOR ═══════════════════════════════════════════

model Vendor {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  // V2.2: Vendor is a 1:1 extension of BusinessAccount. NOT NULL after Step C.
  businessAccountId String @unique @map("business_account_id") @db.Uuid
  businessName  String   @map("business_name") @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  logoUrl       String?  @map("logo_url") @db.VarChar(512)
  bannerUrl     String?  @map("banner_url") @db.VarChar(512)
  rating        Decimal  @default(0) @db.Decimal(2, 1)
  minOrderValue Decimal  @default(0) @map("min_order_value") @db.Decimal(10, 2)
  creditEnabled Boolean  @default(false) @map("credit_enabled")
  isActive      Boolean  @default(true) @map("is_active")
  isVerified    Boolean  @default(false) @map("is_verified")
  // Registered business address — shown on tax invoices as "Bill From / Shipped From".
  addressLine   String?  @map("address_line") @db.Text
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(100)
  addressPincode String? @map("address_pincode") @db.VarChar(10)
  gstNumber     String?  @map("gst_number") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user               User                 @relation(fields: [userId], references: [id])
  businessAccount    BusinessAccount      @relation(fields: [businessAccountId], references: [id])
  serviceAreas       ServiceArea[]
  products           Product[]
  priceSlabs         PriceSlab[]
  inventory          Inventory[]
  deliverySlots      DeliverySlot[]
  orders             Order[]
  cartItems          CartItem[]
  quickOrderLists    QuickOrderList[]
  quickOrderItems    QuickOrderListItem[]
  payments           Payment[]
  creditAccounts     CreditAccount[]
  creditTxns         CreditTransaction[]
  customerVendors    CustomerVendor[]
  collectionProducts CollectionProduct[]
  reviews            Review[]
  teamMembers        VendorTeamMember[]
  documents          VendorDocument[]
  vendorWallet       VendorWallet?
  vendorCustomers    VendorCustomer[]    @relation("VendorCustomerMapping")
  priceLists         PriceList[]
  settlements        VendorSettlement[]
  promotions         Promotion[]
  customerTasks      VendorCustomerTask[]
  customerPrices     VendorCustomerPrice[]
  salespersons       Salesperson[]
  commissionRules    CommissionRule[]
  commissionAccruals CommissionAccrual[]

  // Ordering defaults applied to new products and checkout
  defaultMOQ          Int?      @map("default_moq")
  defaultTaxPercent   Decimal?  @map("default_tax_percent") @db.Decimal(5, 2)
  deliveryFee         Decimal?  @map("delivery_fee") @db.Decimal(10, 2)
  freeDeliveryAbove   Decimal?  @map("free_delivery_above") @db.Decimal(10, 2)
  returnPolicy        String?   @map("return_policy") @db.Text
  cancellationPolicy  String?   @map("cancellation_policy") @db.Text

  // Bank account details for settlements
  bankAccountName   String?  @map("bank_account_name") @db.VarChar(100)
  bankAccountNumber String?  @map("bank_account_number") @db.VarChar(30)
  bankIfsc          String?  @map("bank_ifsc") @db.VarChar(15)
  bankName          String?  @map("bank_name") @db.VarChar(100)
  bankAccountType   String?  @map("bank_account_type") @db.VarChar(20)

  // Enabled payment modes: cod, prepaid, credit, cheque, discco
  paymentModes      String[] @default([]) @map("payment_modes")

  // Per-event per-channel notification preferences JSON
  notificationPrefs Json     @default("{}") @map("notification_prefs")

  // Onboarding wizard fields (collected at /vendor/register)
  tradeName             String?  @map("trade_name") @db.VarChar(255)
  vendorType            String?  @map("vendor_type") @db.VarChar(50)
  panNumber             String?  @map("pan_number") @db.VarChar(20)
  authorizedPersonName  String?  @map("authorized_person_name") @db.VarChar(255)
  authorizedPersonPhone String?  @map("authorized_person_phone") @db.VarChar(20)
  authorizedPersonEmail String?  @map("authorized_person_email") @db.VarChar(255)
  pickupAddressLine     String?  @map("pickup_address_line") @db.Text
  pickupCity            String?  @map("pickup_city") @db.VarChar(100)
  pickupState           String?  @map("pickup_state") @db.VarChar(100)
  pickupPincode         String?  @map("pickup_pincode") @db.VarChar(10)
  deliveryCapability    String?  @map("delivery_capability") @db.VarChar(20)
  fssaiNumber           String?  @map("fssai_number") @db.VarChar(50)
  udyamNumber           String?  @map("udyam_number") @db.VarChar(50)
  cinNumber             String?  @map("cin_number") @db.VarChar(50)

  @@index([slug])
  @@index([isActive])
  @@index([userId])
  @@map("vendors")
}

model ServiceArea {
  id       String  @id @default(uuid()) @db.Uuid
  vendorId String  @map("vendor_id") @db.Uuid
  pincode  String  @db.VarChar(10)
  isActive Boolean @default(true) @map("is_active")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, pincode])
  @@index([pincode])
  @@map("service_areas")
}

model DeliverySlot {
  id         String  @id @default(uuid()) @db.Uuid
  vendorId   String  @map("vendor_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  slotStart  String  @map("slot_start") @db.VarChar(10)
  slotEnd    String  @map("slot_end") @db.VarChar(10)
  cutoffTime String  @map("cutoff_time") @db.VarChar(10)
  isActive   Boolean @default(true) @map("is_active")

  vendor Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([vendorId, dayOfWeek, slotStart])
  @@map("delivery_slots")
}

model CustomerVendor {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  vendorId      String    @map("vendor_id") @db.Uuid
  // V2.2: ownership shifted to (businessAccountId, vendorId). Legacy unique replaced in Step C.
  businessAccountId String @map("business_account_id") @db.Uuid
  isFavorite    Boolean   @default(false) @map("is_favorite")
  lastOrderedAt DateTime? @map("last_ordered_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])

  @@unique([businessAccountId, vendorId])
  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@map("customer_vendors")
}

// ═══ CATALOG ═════════════════════════════════════════

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(255)
  slug      String     @unique @db.VarChar(255)
  parentId  String?    @map("parent_id") @db.Uuid
  imageUrl  String?    @map("image_url") @db.VarChar(512)
  sortOrder Int        @default(0) @map("sort_order")
  isActive       Boolean        @default(true) @map("is_active")
  approvalStatus ApprovalStatus @default(approved) @map("approval_status")
  approvalNote   String?        @map("approval_note") @db.Text
  approvedBy     String?        @map("approved_by") @db.Uuid
  approvedAt     DateTime?      @map("approved_at") @db.Timestamptz
  suggestedBy    String?        @map("suggested_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  productLinks ProductCategory[]
  brandMasterProducts BrandMasterProduct[]

  @@index([parentId])
  @@index([slug])
  @@index([approvalStatus])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  vendorId        String?  @map("vendor_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  name            String   @db.VarChar(255)
  slug            String   @db.VarChar(255)
  description     String?  @db.Text
  imageUrl        String?  @map("image_url") @db.VarChar(512)
  images          String[] @default([]) @map("images")
  packSize        String?  @map("pack_size") @db.VarChar(100)
  unit            String?  @db.VarChar(50)
  sku             String?  @db.VarChar(100)
  hsn             String?  @db.VarChar(50)
  fssaiRef        String?  @map("fssai_ref") @db.VarChar(50)
  brand           String?  @db.VarChar(150)
  barcode         String?  @db.VarChar(100)
  tags            String[] @default([]) @map("tags")
  aliasNames      String[] @default([]) @map("alias_names")
  shelfLifeDays   Int?     @map("shelf_life_days")
  countryOfOrigin String?  @map("country_of_origin") @db.VarChar(100)
  basePrice       Decimal  @map("base_price") @db.Decimal(10, 2)       // Taxable rate (before tax)
  originalPrice   Decimal? @map("original_price") @db.Decimal(10, 2)  // MRP / strikethrough price
  taxPercent      Decimal  @default(0) @map("tax_percent") @db.Decimal(5, 2)
  promoPrice      Decimal? @map("promo_price") @db.Decimal(10, 2)     // Promo taxable rate (single unit)
  promoStartTime  String?  @map("promo_start_time") @db.VarChar(5)    // HH:mm format e.g. "18:00"
  promoEndTime    String?  @map("promo_end_time") @db.VarChar(5)      // HH:mm format e.g. "09:00"
  minOrderQty     Int      @default(1) @map("min_order_qty")
  vegNonVeg       VegType?       @map("veg_non_veg")
  storageType     String?        @map("storage_type") @db.VarChar(50)
  substituteIds   String[]       @default([]) @map("substitute_ids") @db.Uuid
  creditEligible  Boolean        @default(false) @map("credit_eligible")
  isFeatured      Boolean        @default(false) @map("is_featured")
  isActive        Boolean        @default(true) @map("is_active")
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvalNote    String?        @map("approval_note") @db.Text
  approvedBy      String?        @map("approved_by") @db.Uuid
  approvedAt      DateTime?      @map("approved_at") @db.Timestamptz
  // Embedding for AI-assisted brand mapping (Phase 3). Empty array = not yet embedded.
  // embeddingModel records which provider+model produced the vector so we know when to re-embed.
  embedding       Float[]        @default([]) @map("embedding")
  embeddingModel  String?        @map("embedding_model") @db.VarChar(80)
  embeddingUpdatedAt DateTime?   @map("embedding_updated_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor              Vendor?              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id])
  categoryLinks       ProductCategory[]
  priceSlabs          PriceSlab[]
  inventory           Inventory?
  cartItems           CartItem[]
  orderItems          OrderItem[]
  quickOrderListItems QuickOrderListItem[]
  collectionProducts  CollectionProduct[]
  brandMappings       BrandProductMapping[]
  priceListItems      PriceListItem[]
  promoBuyRules       Promotion[]     @relation("PromoBuyProduct")
  promoGetRules       Promotion[]     @relation("PromoGetProduct")
  customerPrices      VendorCustomerPrice[]

  @@unique([vendorId, slug])
  @@index([vendorId])
  @@index([categoryId])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([sku])
  @@map("products")
}

// Join table enabling a product to belong to multiple categories
// (one of them marked isPrimary). Product.categoryId is kept as the
// denormalized primary FK for fast filtering; it mirrors the row where
// isPrimary = true.
model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId, isPrimary])
  @@map("product_categories")
}

model PriceSlab {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  minQty     Int      @map("min_qty")
  maxQty     Int?     @map("max_qty")
  price      Decimal  @db.Decimal(10, 2)            // Regular taxable rate per unit
  promoPrice Decimal? @map("promo_price") @db.Decimal(10, 2) // Promo taxable rate per unit
  sortOrder  Int      @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([productId, minQty])
  @@index([productId])
  @@map("price_slabs")
}

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(512)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  products CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  id           String @id @default(uuid()) @db.Uuid
  collectionId String @map("collection_id") @db.Uuid
  productId    String @map("product_id") @db.Uuid
  vendorId     String @map("vendor_id") @db.Uuid
  sortOrder    Int    @default(0) @map("sort_order")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor     Vendor     @relation(fields: [vendorId], references: [id])

  @@unique([collectionId, productId])
  @@map("collection_products")
}

// ═══ INVENTORY ═══════════════════════════════════════

model Inventory {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @unique @map("product_id") @db.Uuid
  vendorId          String   @map("vendor_id") @db.Uuid
  qtyAvailable      Int      @default(0) @map("qty_available")
  qtyReserved       Int      @default(0) @map("qty_reserved")
  qtyInTransit      Int      @default(0) @map("qty_in_transit")
  qtyDamaged        Int      @default(0) @map("qty_damaged")
  qtyReturned       Int      @default(0) @map("qty_returned")
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("inventory")
}

// ═══ CART ═════════════════════════════════════════════

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // V2.2: cart re-keyed to (userId, businessAccountId, outletId). NOT NULL + composite unique after Step C.
  businessAccountId String @map("business_account_id") @db.Uuid
  outletId          String @map("outlet_id") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id])
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])
  outlet          Outlet          @relation(fields: [outletId], references: [id])
  items           CartItem[]

  @@unique([userId, businessAccountId, outletId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([vendorId])
  @@map("cart_items")
}

// ═══ ORDERS ══════════════════════════════════════════

model Order {
  id             String       @id @default(uuid()) @db.Uuid
  orderNumber    String       @unique @map("order_number") @db.VarChar(50)
  userId         String       @map("user_id") @db.Uuid
  vendorId       String       @map("vendor_id") @db.Uuid
  // V2.2: outlet-stamped order with snapshotted delivery address. NOT NULL after Step C.
  businessAccountId        String @map("business_account_id") @db.Uuid
  outletId                 String @map("outlet_id") @db.Uuid
  deliveryAddressSnapshot  Json   @map("delivery_address_snapshot")
  status         OrderStatus  @default(pending)
  subtotal       Decimal      @db.Decimal(12, 2)
  promoDiscount  Decimal      @default(0) @map("promo_discount") @db.Decimal(10, 2)
  promotionId    String?      @map("promotion_id") @db.Uuid
  taxAmount      Decimal      @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal      @map("total_amount") @db.Decimal(12, 2)
  paymentMethod  String?      @map("payment_method") @db.VarChar(30)
  paymentStatus  PaymentState @default(unpaid) @map("payment_status")
  deliverySlotId String?      @map("delivery_slot_id") @db.Uuid
  deliveryDate   DateTime?    @map("delivery_date") @db.Date
  notes              String?      @db.Text
  rejectionReason    String?      @map("rejection_reason") @db.Text
  acceptedAt         DateTime?    @map("accepted_at") @db.Timestamptz
  rejectedAt         DateTime?    @map("rejected_at") @db.Timestamptz
  isPartial          Boolean      @default(false) @map("is_partial")
  deliveryProofType  String?      @map("delivery_proof_type") @db.VarChar(20)
  deliveryProofUrl   String?      @map("delivery_proof_url") @db.Text
  deliveryNotes      String?      @map("delivery_notes") @db.Text
  deliveredAt        DateTime?    @map("delivered_at") @db.Timestamptz
  ewayBillNo         String?      @map("eway_bill_no") @db.VarChar(30)
  // V2.2 Phase 1 — salesman attribution. Snapshotted at order creation
  // so commission survives reassignment of the customer's salesperson later.
  salespersonId      String?      @map("salesperson_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  promotion       Promotion?      @relation(fields: [promotionId], references: [id])
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])
  outlet          Outlet          @relation(fields: [outletId], references: [id])
  deliverySlot    DeliverySlot?   @relation(fields: [deliverySlotId], references: [id])
  salesperson     Salesperson?    @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  creditTxns     CreditTransaction[]
  review         Review?
  returnRequest  ReturnRequest?
  commissionAccruals CommissionAccrual[]

  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@index([outletId])
  @@index([status])
  @@index([salespersonId])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
}

enum PaymentState {
  unpaid
  paid
  partial
  refunded
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName  String  @map("product_name") @db.VarChar(255)
  quantity     Int
  fulfilledQty Int     @default(0) @map("fulfilled_qty")
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal @map("total_price") @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ═══ REVIEWS ═════════════════════════════════════════

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  rating    Int      // 1–5 stars
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@map("reviews")
}

// ═══ QUICK ORDER LISTS ═══════════════════════════════

model QuickOrderList {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  // V2.2: scope = (businessAccountId, vendorId). userId stays as creator/audit metadata.
  businessAccountId String @map("business_account_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor                 @relation(fields: [vendorId], references: [id])
  businessAccount BusinessAccount        @relation(fields: [businessAccountId], references: [id])
  items           QuickOrderListItem[]

  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@map("quick_order_lists")
}

model QuickOrderListItem {
  id         String @id @default(uuid()) @db.Uuid
  listId     String @map("list_id") @db.Uuid
  productId  String @map("product_id") @db.Uuid
  vendorId   String @map("vendor_id") @db.Uuid
  defaultQty Int    @default(0) @map("default_qty")
  sortOrder  Int    @default(0) @map("sort_order")

  list    QuickOrderList @relation(fields: [listId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  vendor  Vendor         @relation(fields: [vendorId], references: [id])

  @@unique([listId, productId])
  @@index([listId])
