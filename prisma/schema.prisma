generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══ AUTH.JS MODELS ═══════════════════════════════════
// Required by @auth/prisma-adapter for session management

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}


// ═══ USER ═════════════════════════════════════════════

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  password      String?   @db.VarChar(255)
  phone         String?   @unique @db.VarChar(20)
  fullName      String    @default("") @map("full_name") @db.VarChar(255)
  image         String?   @db.VarChar(512)
  role          Role      @default(customer)
  pincode       String?   @db.VarChar(10)
  businessName  String?   @map("business_name") @db.VarChar(255)
  gstNumber     String?   @map("gst_number") @db.VarChar(20)
  isActive      Boolean   @default(true) @map("is_active")
  profileCompletedAt DateTime? @map("profile_completed_at") @db.Timestamptz
  // V2.2: human-readable HCID display, e.g. "HC-A4F2-9X3K". Generated at signup via src/lib/hcid.ts.
  hcidDisplay   String    @unique @map("hcid_display") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  accounts Account[]
  sessions Session[]

  linkedAccounts  LinkedAccount[] @relation("MyLinks")
  linkedBy        LinkedAccount[] @relation("LinkedToMe")

  vendors         Vendor[]
  brands          Brand[]
  carts           Cart[]   // V2.2: one cart per (businessAccountId, outletId)
  wallet          Wallet?
  orders          Order[]
  quickOrderLists QuickOrderList[]
  customerVendors CustomerVendor[]
  creditAccounts  CreditAccount[]
  creditWallets   CreditWallet[]
  notifications   Notification[]
  reviews         Review[]
  vendorCustomers VendorCustomer[] @relation("VendorCustomerUser")

  vendorMemberships VendorTeamMember[] @relation("VendorMemberships")
  vendorInvitesSent VendorTeamMember[] @relation("VendorInvites")
  brandMemberships  BrandTeamMember[]  @relation("BrandMemberships")
  brandInvitesSent  BrandTeamMember[]  @relation("BrandInvites")
  adminMembership   AdminTeamMember?   @relation("AdminMembership")
  adminInvitesSent  AdminTeamMember[]  @relation("AdminInvites")
  savedAddresses    SavedAddress[]
  returnRequests    ReturnRequest[] @relation("CustomerReturnRequests")
  pushSubscriptions PushSubscription[]

  // V2.2 — multi-account access
  accountMemberships BusinessAccountMember[] @relation("UserAccountMembership")
  accountInvitesSent BusinessAccountMember[] @relation("AccountInvites")
  userRoles          UserRole[]              @relation("UserRoles")

  // V2.2 Phase 1 — Salesman Commission
  salespersonProfile     Salesperson[]        @relation("UserSalespersonProfile")
  approvedAccruals       CommissionAccrual[]  @relation("CommissionApprover")

  // V2.2 Phase 4 — Pricelist assignments targeting this user
  priceListAssignments   PriceListAssignment[] @relation("PriceListAssignmentUser")

  // Promo Engine Phase 1 — cashback earned by this user (order-linked + direct grants)
  cashbackEntries        CashbackEntry[]

  @@index([email])
  @@index([phone])
  @@index([pincode])
  @@index([role])
  @@map("users")
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum Role {
  customer
  vendor
  admin
  brand
}

enum TeamRole {
  owner
  manager
  editor
  viewer
}

// ═══ LINKED ACCOUNTS (multi-account switcher) ════════

model LinkedAccount {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  linkedUserId String   @map("linked_user_id") @db.Uuid
  switchToken  String   @unique @default(uuid()) @map("switch_token") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user       User @relation("MyLinks", fields: [userId], references: [id], onDelete: Cascade)
  linkedUser User @relation("LinkedToMe", fields: [linkedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, linkedUserId])
  @@index([userId])
  @@index([switchToken])
  @@map("linked_accounts")
}

// ═══ VENDOR ═══════════════════════════════════════════

model Vendor {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  // V2.2: Vendor is a 1:1 extension of BusinessAccount. NOT NULL after Step C.
  businessAccountId String @unique @map("business_account_id") @db.Uuid
  businessName  String   @map("business_name") @db.VarChar(255)
  slug          String   @unique @db.VarChar(255)
  description   String?  @db.Text
  logoUrl       String?  @map("logo_url") @db.VarChar(512)
  bannerUrl     String?  @map("banner_url") @db.VarChar(512)
  rating        Decimal  @default(0) @db.Decimal(2, 1)
  minOrderValue Decimal  @default(0) @map("min_order_value") @db.Decimal(10, 2)
  creditEnabled Boolean  @default(false) @map("credit_enabled")
  isActive      Boolean  @default(true) @map("is_active")
  isVerified    Boolean  @default(false) @map("is_verified")
  // Registered business address — shown on tax invoices as "Bill From / Shipped From".
  addressLine   String?  @map("address_line") @db.Text
  city          String?  @db.VarChar(100)
  state         String?  @db.VarChar(100)
  addressPincode String? @map("address_pincode") @db.VarChar(10)
  gstNumber     String?  @map("gst_number") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user               User                 @relation(fields: [userId], references: [id])
  businessAccount    BusinessAccount      @relation(fields: [businessAccountId], references: [id])
  serviceAreas       ServiceArea[]
  products           Product[]
  priceSlabs         PriceSlab[]
  inventory          Inventory[]
  deliverySlots      DeliverySlot[]
  orders             Order[]
  cartItems          CartItem[]
  quickOrderLists    QuickOrderList[]
  quickOrderItems    QuickOrderListItem[]
  payments           Payment[]
  creditAccounts     CreditAccount[]
  creditWallets      CreditWallet[]
  creditTxns         CreditTransaction[]
  customerVendors    CustomerVendor[]
  collectionProducts CollectionProduct[]
  reviews            Review[]
  teamMembers        VendorTeamMember[]
  documents          VendorDocument[]
  vendorWallet       VendorWallet?
  vendorCustomers    VendorCustomer[]    @relation("VendorCustomerMapping")
  priceLists         PriceList[]
  settlements        VendorSettlement[]
  promotions         Promotion[]
  customerTasks      VendorCustomerTask[]
  customerPrices     VendorCustomerPrice[]
  salespersons       Salesperson[]
  commissionRules    CommissionRule[]
  commissionAccruals CommissionAccrual[]
  coupons            Coupon[]
  cashbackCampaigns  CashbackCampaign[]
  customerGroups     CustomerGroup[]
  combos             ProductCombo[]

  // Ordering defaults applied to new products and checkout
  defaultMOQ          Int?      @map("default_moq")
  defaultTaxPercent   Decimal?  @map("default_tax_percent") @db.Decimal(5, 2)
  deliveryFee         Decimal?  @map("delivery_fee") @db.Decimal(10, 2)
  freeDeliveryAbove   Decimal?  @map("free_delivery_above") @db.Decimal(10, 2)
  returnPolicy        String?   @map("return_policy") @db.Text
  cancellationPolicy  String?   @map("cancellation_policy") @db.Text

  // Bank account details for settlements
  bankAccountName   String?  @map("bank_account_name") @db.VarChar(100)
  bankAccountNumber String?  @map("bank_account_number") @db.VarChar(30)
  bankIfsc          String?  @map("bank_ifsc") @db.VarChar(15)
  bankName          String?  @map("bank_name") @db.VarChar(100)
  bankAccountType   String?  @map("bank_account_type") @db.VarChar(20)

  // Enabled payment modes: cod, prepaid, credit, cheque, discco
  paymentModes      String[] @default([]) @map("payment_modes")

  // Per-event per-channel notification preferences JSON
  notificationPrefs Json     @default("{}") @map("notification_prefs")

  // Onboarding wizard fields (collected at /vendor/register)
  tradeName             String?  @map("trade_name") @db.VarChar(255)
  vendorType            String?  @map("vendor_type") @db.VarChar(50)
  panNumber             String?  @map("pan_number") @db.VarChar(20)
  authorizedPersonName  String?  @map("authorized_person_name") @db.VarChar(255)
  authorizedPersonPhone String?  @map("authorized_person_phone") @db.VarChar(20)
  authorizedPersonEmail String?  @map("authorized_person_email") @db.VarChar(255)
  pickupAddressLine     String?  @map("pickup_address_line") @db.Text
  pickupCity            String?  @map("pickup_city") @db.VarChar(100)
  pickupState           String?  @map("pickup_state") @db.VarChar(100)
  pickupPincode         String?  @map("pickup_pincode") @db.VarChar(10)
  deliveryCapability    String?  @map("delivery_capability") @db.VarChar(20)
  fssaiNumber           String?  @map("fssai_number") @db.VarChar(50)
  udyamNumber           String?  @map("udyam_number") @db.VarChar(50)
  cinNumber             String?  @map("cin_number") @db.VarChar(50)

  // Profile Mastersheet — Tier A onboarding (CSV rows 13–20, attribute master 72–83)
  subType               String?   @map("sub_type") @db.VarChar(80)
  categoriesHandled     String[]  @default([]) @map("categories_handled")
  businessSize          String?   @map("business_size") @db.VarChar(50)
  coverage              String?   @db.VarChar(120)
  warehouseCount        Int?      @map("warehouse_count")
  deliveryFleet         Boolean?  @map("delivery_fleet")
  monthlySupplyBand     String?   @map("monthly_supply_band") @db.VarChar(50)

  @@index([slug])
  @@index([isActive])
  @@index([userId])
  @@map("vendors")
}

model ServiceArea {
  id       String  @id @default(uuid()) @db.Uuid
  vendorId String  @map("vendor_id") @db.Uuid
  pincode  String  @db.VarChar(10)
  isActive Boolean @default(true) @map("is_active")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, pincode])
  @@index([pincode])
  @@map("service_areas")
}

model DeliverySlot {
  id         String  @id @default(uuid()) @db.Uuid
  vendorId   String  @map("vendor_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  slotStart  String  @map("slot_start") @db.VarChar(10)
  slotEnd    String  @map("slot_end") @db.VarChar(10)
  cutoffTime String  @map("cutoff_time") @db.VarChar(10)
  isActive   Boolean @default(true) @map("is_active")

  vendor Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([vendorId, dayOfWeek, slotStart])
  @@map("delivery_slots")
}

model CustomerVendor {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  vendorId      String    @map("vendor_id") @db.Uuid
  // V2.2: ownership shifted to (businessAccountId, vendorId). Legacy unique replaced in Step C.
  businessAccountId String @map("business_account_id") @db.Uuid
  isFavorite    Boolean   @default(false) @map("is_favorite")
  lastOrderedAt DateTime? @map("last_ordered_at") @db.Timestamptz
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])

  @@unique([businessAccountId, vendorId])
  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@map("customer_vendors")
}

// ═══ CATALOG ═════════════════════════════════════════

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  name      String     @db.VarChar(255)
  slug      String     @unique @db.VarChar(255)
  parentId  String?    @map("parent_id") @db.Uuid
  imageUrl  String?    @map("image_url") @db.VarChar(512)
  sortOrder Int        @default(0) @map("sort_order")
  isActive       Boolean        @default(true) @map("is_active")
  approvalStatus ApprovalStatus @default(approved) @map("approval_status")
  approvalNote   String?        @map("approval_note") @db.Text
  approvedBy     String?        @map("approved_by") @db.Uuid
  approvedAt     DateTime?      @map("approved_at") @db.Timestamptz
  suggestedBy    String?        @map("suggested_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  productLinks ProductCategory[]
  brandMasterProducts BrandMasterProduct[]
  masterProducts MasterProduct[]

  @@index([parentId])
  @@index([slug])
  @@index([approvalStatus])
  @@map("categories")
}

model Product {
  id              String   @id @default(uuid()) @db.Uuid
  vendorId        String?  @map("vendor_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  // Central "Horeca1 SKU" master this vendor listing maps to. Column is nullable
  // at the DB level during the backfill window; presence is enforced at the
  // application layer (Zod + catalog.service) so every new product picks a master.
  // A follow-up migration flips this to NOT NULL once backfill verifies 0 nulls.
  masterProductId String?  @map("master_product_id") @db.Uuid
  name            String   @db.VarChar(255)
  slug            String   @db.VarChar(255)
  description     String?  @db.Text
  imageUrl        String?  @map("image_url") @db.VarChar(512)
  images          String[] @default([]) @map("images")
  packSize        String?  @map("pack_size") @db.VarChar(100)
  unit            String?  @db.VarChar(50)
  sku             String?  @db.VarChar(100)
  hsn             String?  @db.VarChar(50)
  fssaiRef        String?  @map("fssai_ref") @db.VarChar(50)
  brand           String?  @db.VarChar(150)
  barcode         String?  @db.VarChar(100)
  tags            String[] @default([]) @map("tags")
  aliasNames      String[] @default([]) @map("alias_names")
  shelfLifeDays   Int?     @map("shelf_life_days")
  countryOfOrigin String?  @map("country_of_origin") @db.VarChar(100)
  basePrice       Decimal  @map("base_price") @db.Decimal(10, 2)       // Taxable rate (before tax)
  originalPrice   Decimal? @map("original_price") @db.Decimal(10, 2)  // MRP / strikethrough price
  taxPercent      Decimal  @default(0) @map("tax_percent") @db.Decimal(5, 2)
  promoPrice      Decimal? @map("promo_price") @db.Decimal(10, 2)     // Promo taxable rate (single unit)
  promoStartTime  String?  @map("promo_start_time") @db.VarChar(5)    // HH:mm format e.g. "18:00"
  promoEndTime    String?  @map("promo_end_time") @db.VarChar(5)      // HH:mm format e.g. "09:00"
  minOrderQty     Int      @default(1) @map("min_order_qty")
  vegNonVeg       VegType?       @map("veg_non_veg")
  storageType     String?        @map("storage_type") @db.VarChar(50)
  substituteIds   String[]       @default([]) @map("substitute_ids") @db.Uuid
  creditEligible  Boolean        @default(false) @map("credit_eligible")
  isFeatured      Boolean        @default(false) @map("is_featured")
  isActive        Boolean        @default(true) @map("is_active")
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  approvalNote    String?        @map("approval_note") @db.Text
  approvedBy      String?        @map("approved_by") @db.Uuid
  approvedAt      DateTime?      @map("approved_at") @db.Timestamptz
  // Embedding for AI-assisted brand mapping (Phase 3). Empty array = not yet embedded.
  // embeddingModel records which provider+model produced the vector so we know when to re-embed.
  embedding       Float[]        @default([]) @map("embedding")
  embeddingModel  String?        @map("embedding_model") @db.VarChar(80)
  embeddingUpdatedAt DateTime?   @map("embedding_updated_at") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor              Vendor?              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category            Category?            @relation(fields: [categoryId], references: [id])
  masterProduct       MasterProduct?       @relation("MasterToVendorProduct", fields: [masterProductId], references: [id], onDelete: Restrict)
  categoryLinks       ProductCategory[]
  priceSlabs          PriceSlab[]
  inventory           Inventory?
  cartItems           CartItem[]
  orderItems          OrderItem[]
  quickOrderListItems QuickOrderListItem[]
  collectionProducts  CollectionProduct[]
  brandMappings       BrandProductMapping[]
  priceListItems      PriceListItem[]
  promoBuyRules       Promotion[]     @relation("PromoBuyProduct")
  promoGetRules       Promotion[]     @relation("PromoGetProduct")
  customerPrices      VendorCustomerPrice[]
  comboItems          ComboItem[]

  @@unique([vendorId, slug])
  @@index([vendorId])
  @@index([categoryId])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([sku])
  @@index([masterProductId])
  @@map("products")
}

// Join table enabling a product to belong to multiple categories
// (one of them marked isPrimary). Product.categoryId is kept as the
// denormalized primary FK for fast filtering; it mirrors the row where
// isPrimary = true.
model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
  @@index([productId, isPrimary])
  @@map("product_categories")
}

// ═══ MASTER PRODUCT (Horeca1 canonical SKU) ═══════════
// Platform-owned (Horeca1) canonical item. Distinct from BrandMasterProduct
// (which is brand-owned). Vendor `Product` rows map to exactly one MasterProduct
// (enforced at the application layer; DB FK is nullable during backfill, flipped
// to NOT NULL by a follow-up migration). `categoryId` MUST be a leaf (level-2)
// sub-category — enforced by assertLeafCategory in catalog.service.ts.
model MasterProduct {
  id             String   @id @default(uuid()) @db.Uuid
  sku            String   @unique @db.VarChar(40)              // Admin-entered canonical SKU (e.g. RIC-BAS-001)
  name           String   @db.VarChar(255)
  aliasNames     String[] @default([]) @map("alias_names")
  brand          String?  @db.VarChar(150)
  uom            String?  @db.VarChar(50)
  taxPercent     Decimal  @default(0) @map("tax_percent") @db.Decimal(5, 2)
  imageUrl       String?  @map("image_url") @db.VarChar(512)
  images         String[] @default([]) @map("images")
  searchKeywords String[] @default([]) @map("search_keywords")
  categoryId     String   @map("category_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  approvalStatus ApprovalStatus @default(approved) @map("approval_status")
  approvalNote   String?        @map("approval_note") @db.Text
  approvedBy     String?        @map("approved_by") @db.Uuid
  approvedAt     DateTime?      @map("approved_at") @db.Timestamptz
  suggestedBy    String?        @map("suggested_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  category            Category             @relation(fields: [categoryId], references: [id])
  vendorProducts      Product[]            @relation("MasterToVendorProduct")
  brandMasterProducts BrandMasterProduct[]

  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@index([approvalStatus])
  @@map("master_products")
}

model PriceSlab {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  minQty     Int      @map("min_qty")
  maxQty     Int?     @map("max_qty")
  price      Decimal  @db.Decimal(10, 2)            // Regular taxable rate per unit
  promoPrice Decimal? @map("promo_price") @db.Decimal(10, 2) // Promo taxable rate per unit
  sortOrder  Int      @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([productId, minQty])
  @@index([productId])
  @@map("price_slabs")
}

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(512)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  products CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  id           String @id @default(uuid()) @db.Uuid
  collectionId String @map("collection_id") @db.Uuid
  productId    String @map("product_id") @db.Uuid
  vendorId     String @map("vendor_id") @db.Uuid
  sortOrder    Int    @default(0) @map("sort_order")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor     Vendor     @relation(fields: [vendorId], references: [id])

  @@unique([collectionId, productId])
  @@map("collection_products")
}

// ═══ COMBO / BUNDLE ═══════════════════════════════════
// A vendor-owned bundle of products sold together at one combo price. Created
// from a selection in the Bulk Update Engine (combo pricing). comboPrice is the
// taxable bundle rate; originalPrice (optional) is the summed list price for a
// strikethrough. Optional validity window gates when the combo is live.
model ProductCombo {
  id            String   @id @default(uuid()) @db.Uuid
  vendorId      String   @map("vendor_id") @db.Uuid
  name          String   @db.VarChar(255)
  comboPrice    Decimal  @map("combo_price") @db.Decimal(10, 2)
  originalPrice Decimal? @map("original_price") @db.Decimal(10, 2)
  imageUrl      String?  @map("image_url") @db.VarChar(512)
  isActive      Boolean  @default(true) @map("is_active")
  validFrom     DateTime? @map("valid_from") @db.Timestamptz
  validTo       DateTime? @map("valid_to") @db.Timestamptz
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  ComboItem[]

  @@index([vendorId])
  @@index([isActive])
  @@map("product_combos")
}

model ComboItem {
  id        String @id @default(uuid()) @db.Uuid
  comboId   String @map("combo_id") @db.Uuid
  productId String @map("product_id") @db.Uuid
  qty       Int    @default(1)

  combo   ProductCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([comboId, productId])
  @@index([comboId])
  @@index([productId])
  @@map("combo_items")
}

// ═══ INVENTORY ═══════════════════════════════════════

model Inventory {
  id                String   @id @default(uuid()) @db.Uuid
  productId         String   @unique @map("product_id") @db.Uuid
  vendorId          String   @map("vendor_id") @db.Uuid
  qtyAvailable      Int      @default(0) @map("qty_available")
  qtyReserved       Int      @default(0) @map("qty_reserved")
  qtyInTransit      Int      @default(0) @map("qty_in_transit")
  qtyDamaged        Int      @default(0) @map("qty_damaged")
  qtyReturned       Int      @default(0) @map("qty_returned")
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("inventory")
}

// ═══ CART ═════════════════════════════════════════════

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  // V2.2: cart re-keyed to (userId, businessAccountId, outletId). NOT NULL + composite unique after Step C.
  businessAccountId String @map("business_account_id") @db.Uuid
  outletId          String @map("outlet_id") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id])
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])
  outlet          Outlet          @relation(fields: [outletId], references: [id])
  items           CartItem[]

  @@unique([userId, businessAccountId, outletId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  vendor  Vendor  @relation(fields: [vendorId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([vendorId])
  @@map("cart_items")
}

// ═══ ORDERS ══════════════════════════════════════════

model Order {
  id             String       @id @default(uuid()) @db.Uuid
  orderNumber    String       @unique @map("order_number") @db.VarChar(50)
  userId         String       @map("user_id") @db.Uuid
  vendorId       String       @map("vendor_id") @db.Uuid
  // V2.2: outlet-stamped order with snapshotted delivery address. NOT NULL after Step C.
  businessAccountId        String @map("business_account_id") @db.Uuid
  outletId                 String @map("outlet_id") @db.Uuid
  deliveryAddressSnapshot  Json   @map("delivery_address_snapshot")
  status         OrderStatus  @default(pending)
  subtotal       Decimal      @db.Decimal(12, 2)
  promoDiscount  Decimal      @default(0) @map("promo_discount") @db.Decimal(10, 2)
  promotionId    String?      @map("promotion_id") @db.Uuid
  // Promo Engine Phase 1 — coupon applied at checkout (code snapshotted so the
  // order history survives coupon deletion) + prepaid-wallet amount redeemed.
  couponId       String?      @map("coupon_id") @db.Uuid
  couponCode     String?      @map("coupon_code") @db.VarChar(40)
  couponDiscount Decimal      @default(0) @map("coupon_discount") @db.Decimal(10, 2)
  walletApplied  Decimal      @default(0) @map("wallet_applied") @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount    Decimal      @map("total_amount") @db.Decimal(12, 2)
  paymentMethod  String?      @map("payment_method") @db.VarChar(30)
  paymentStatus  PaymentState @default(unpaid) @map("payment_status")
  deliverySlotId String?      @map("delivery_slot_id") @db.Uuid
  deliveryDate   DateTime?    @map("delivery_date") @db.Date
  notes              String?      @db.Text
  rejectionReason    String?      @map("rejection_reason") @db.Text
  acceptedAt         DateTime?    @map("accepted_at") @db.Timestamptz
  rejectedAt         DateTime?    @map("rejected_at") @db.Timestamptz
  isPartial          Boolean      @default(false) @map("is_partial")
  deliveryProofType  String?      @map("delivery_proof_type") @db.VarChar(20)
  deliveryProofUrl   String?      @map("delivery_proof_url") @db.Text
  deliveryNotes      String?      @map("delivery_notes") @db.Text
  customerDeleted    Boolean      @default(false) @map("customer_deleted")
  // V2.2 Phase 5 — delivery OTP proof. Generated when the order goes out for
  // delivery, sent to the customer, and verified on the delivered transition
  // when proofType='otp'. Fully optional — alternate proof types ignore these.
  deliveryOtp           String?   @map("delivery_otp") @db.VarChar(6)
  deliveryOtpExpiresAt  DateTime? @map("delivery_otp_expires_at") @db.Timestamptz
  deliveryOtpVerifiedAt DateTime? @map("delivery_otp_verified_at") @db.Timestamptz
  deliveredAt        DateTime?    @map("delivered_at") @db.Timestamptz
  ewayBillNo         String?      @map("eway_bill_no") @db.VarChar(30)
  // V2.2 Phase 1 — salesman attribution. Snapshotted at order creation
  // so commission survives reassignment of the customer's salesperson later.
  salespersonId      String?      @map("salesperson_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User            @relation(fields: [userId], references: [id])
  vendor          Vendor          @relation(fields: [vendorId], references: [id])
  promotion       Promotion?      @relation(fields: [promotionId], references: [id])
  coupon          Coupon?         @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponRedemption CouponRedemption?
  cashbackEntry   CashbackEntry?
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id])
  outlet          Outlet          @relation(fields: [outletId], references: [id])
  deliverySlot    DeliverySlot?   @relation(fields: [deliverySlotId], references: [id])
  salesperson     Salesperson?    @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  creditTxns     CreditTransaction[]
  review         Review?
  returnRequest  ReturnRequest?
  commissionAccruals CommissionAccrual[]

  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@index([outletId])
  @@index([status])
  @@index([salespersonId])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

enum OrderStatus {
  draft               // V2.2 Phase 5 — saved PO, not yet submitted (no reservation)
  pending
  confirmed
  processing
  ready_for_dispatch  // V2.2 Phase 5 — packed, awaiting pickup
  shipped
  partially_delivered // V2.2 Phase 5 — some lines delivered, balance pending
  delivered
  returned            // V2.2 Phase 5 — goods returned after delivery
  cancelled
}

enum PaymentState {
  unpaid
  paid
  partial
  refunded
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName  String  @map("product_name") @db.VarChar(255)
  quantity     Int
  fulfilledQty Int     @default(0) @map("fulfilled_qty")
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal @map("total_price") @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ═══ REVIEWS ═════════════════════════════════════════

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  rating    Int      // 1–5 stars
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([userId])
  @@map("reviews")
}

// ═══ QUICK ORDER LISTS ═══════════════════════════════

model QuickOrderList {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  // V2.2: scope = (businessAccountId, vendorId). userId stays as creator/audit metadata.
  businessAccountId String @map("business_account_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor          Vendor                 @relation(fields: [vendorId], references: [id])
  businessAccount BusinessAccount        @relation(fields: [businessAccountId], references: [id])
  items           QuickOrderListItem[]

  @@index([userId])
  @@index([vendorId])
  @@index([businessAccountId])
  @@map("quick_order_lists")
}

model QuickOrderListItem {
  id         String @id @default(uuid()) @db.Uuid
  listId     String @map("list_id") @db.Uuid
  productId  String @map("product_id") @db.Uuid
  vendorId   String @map("vendor_id") @db.Uuid
  defaultQty Int    @default(0) @map("default_qty")
  sortOrder  Int    @default(0) @map("sort_order")

  list    QuickOrderList @relation(fields: [listId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  vendor  Vendor         @relation(fields: [vendorId], references: [id])

  @@unique([listId, productId])
  @@index([listId])
  @@map("quick_order_list_items")
}

// ═══ PAYMENTS ════════════════════════════════════════

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  orderId           String        @map("order_id") @db.Uuid
  vendorId          String        @map("vendor_id") @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  razorpayOrderId   String?       @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId String?       @map("razorpay_payment_id") @db.VarChar(100)
  razorpaySignature String?       @map("razorpay_signature") @db.VarChar(255)
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("INR") @db.VarChar(10)
  status            PaymentStatus @default(created)
  method            String?       @db.VarChar(30)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  order  Order  @relation(fields: [orderId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([orderId])
  @@index([razorpayOrderId])
  @@map("payments")
}

enum PaymentStatus {
  created
  authorized
  captured
  failed
  refunded
}

// ═══ CREDIT (DiSCCO) ════════════════════════════════

model CreditAccount {
  id                  String       @id @default(uuid()) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  vendorId            String       @map("vendor_id") @db.Uuid
  creditLimit         Decimal      @default(0) @map("credit_limit") @db.Decimal(12, 2)
  creditUsed          Decimal      @default(0) @map("credit_used") @db.Decimal(12, 2)
  status              CreditStatus @default(pending)
  graceDays           Int          @default(0) @map("grace_days")
  interestRatePct     Decimal      @default(0) @map("interest_rate_pct") @db.Decimal(5, 2)
  penaltyRatePct      Decimal      @default(0) @map("penalty_rate_pct") @db.Decimal(5, 2)
  freezeOnOverdueDays Int          @default(0) @map("freeze_on_overdue_days")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User                @relation(fields: [userId], references: [id])
  vendor       Vendor              @relation(fields: [vendorId], references: [id])
  transactions CreditTransaction[]

  @@unique([userId, vendorId])
  @@map("credit_accounts")
}

enum CreditStatus {
  pending
  active
  suspended
  closed
}

model CreditTransaction {
  id              String        @id @default(uuid()) @db.Uuid
  creditAccountId String        @map("credit_account_id") @db.Uuid
  orderId         String?       @map("order_id") @db.Uuid
  vendorId        String        @map("vendor_id") @db.Uuid
  type            CreditTxnType
  amount          Decimal       @db.Decimal(12, 2)
  balanceAfter    Decimal       @map("balance_after") @db.Decimal(12, 2)
  dueDate         DateTime?     @map("due_date") @db.Date
  notes           String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  creditAccount CreditAccount @relation(fields: [creditAccountId], references: [id])
  order         Order?        @relation(fields: [orderId], references: [id])
  vendor        Vendor        @relation(fields: [vendorId], references: [id])

  @@index([creditAccountId])
  @@map("credit_transactions")
}

enum CreditTxnType {
  debit
  credit
  adjustment
}

// ═══ WALLET ═════════════════════════════════════════

model Wallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user         User                @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id            String        @id @default(uuid()) @db.Uuid
  walletId      String        @map("wallet_id") @db.Uuid
  type          WalletTxnType
  amount        Decimal       @db.Decimal(12, 2)
  referenceId   String?       @map("reference_id") @db.Uuid
  referenceType String?       @map("reference_type") @db.VarChar(30)
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@map("wallet_transactions")
}

enum WalletTxnType {
  credit
  debit
}

enum CreditWalletStatus {
  ACTIVE
  BLOCKED
  BLACKLISTED

  @@map("credit_wallet_status")
}

enum CreditWalletTxnType {
  CREDIT_ASSIGN
  ORDER_DEBIT
  REPAYMENT
  PENALTY
  REVERSAL

  @@map("credit_wallet_txn_type")
}

enum CreditRepaymentMode {
  REPAY_BEFORE_NEXT_USE
  ALLOW_USAGE_TILL_DUE

  @@map("credit_repayment_mode")
}

enum BillingModelType {
  BILL_TO_BILL
  WEEKLY
  FORTNIGHTLY
  MONTHLY

  @@map("billing_model_type")
}

enum CreditPenaltyType {
  LATE_FEE
  INTEREST

  @@map("credit_penalty_type")
}

// Singleton global defaults. Every parameter is overridable per wallet (see
// CreditWallet.override*). interest/penalty frequency are in DAYS so "1% per 2 days"
// is expressible. unlockCreditAmount powers "buy X times -> unlock up to ₹Y".
model GlobalCreditConfig {
  id                    String              @id @default(uuid()) @db.Uuid
  repaymentMode         CreditRepaymentMode @default(REPAY_BEFORE_NEXT_USE)
  billingModel          BillingModelType    @default(BILL_TO_BILL)
  creditLimit           Decimal             @default(1000) @db.Decimal(12, 2)
  creditTenureDays      Int                 @default(3)
  gracePeriodDays       Int                 @default(2)
  blacklistDays         Int                 @default(10)
  interestRatePct       Decimal             @default(1.0) @db.Decimal(6, 3)
  interestFrequencyDays Int                 @default(1) @map("interest_frequency_days")
  penaltyAmount         Decimal             @default(10.0) @db.Decimal(12, 2)
  penaltyFrequencyDays  Int                 @default(1) @map("penalty_frequency_days")
  eligiblePurchaseCount Int                 @default(3) @map("eligible_purchase_count")
  unlockCreditAmount    Decimal             @default(10000) @map("unlock_credit_amount") @db.Decimal(12, 2)
  updatedAt             DateTime            @default(now()) @updatedAt @db.Timestamptz

  @@map("global_credit_configs")
}

// One credit line. vendorId = null -> H1 platform wallet; non-null -> vendor credit.
// Same config engine for both (V1). Uniqueness: one wallet per (user, vendor) and one
// H1 wallet per user — enforced by partial unique indexes in the migration (a Prisma
// @@unique on a nullable column does NOT stop duplicate NULLs in Postgres).
model CreditWallet {
  id                    String              @id @default(uuid()) @db.Uuid
  userId                String              @map("user_id") @db.Uuid
  vendorId              String?             @map("vendor_id") @db.Uuid
  status                CreditWalletStatus  @default(ACTIVE)

  creditLimit           Decimal             @map("credit_limit") @db.Decimal(12, 2)
  availableCredit       Decimal             @map("available_credit") @db.Decimal(12, 2)
  usedCredit            Decimal             @default(0) @map("used_credit") @db.Decimal(12, 2)
  outstandingAmount     Decimal             @default(0) @map("outstanding_amount") @db.Decimal(12, 2)

  // Principal captured when the wallet first goes overdue — compound interest is
  // computed on (this + accrued interest), NOT on the live outstanding (which would
  // double-compound late fees + prior interest).
  overdueBaseAmount     Decimal?            @map("overdue_base_amount") @db.Decimal(12, 2)

  currentDueDate        DateTime?           @map("current_due_date") @db.Timestamptz
  lastUtilizationDate   DateTime?           @map("last_utilization_date") @db.Timestamptz
  overdueDays           Int                 @default(0) @map("overdue_days")

  // Manual reactivation with dues: scheduler must NOT immediately re-blacklist.
  blacklistExempt       Boolean             @default(false) @map("blacklist_exempt")
  blacklistedAt         DateTime?           @map("blacklisted_at") @db.Timestamptz
  reactivatedAt         DateTime?           @map("reactivated_at") @db.Timestamptz

  overrideRepaymentMode   CreditRepaymentMode? @map("override_repayment_mode")
  overrideBillingModel    BillingModelType?    @map("override_billing_model")
  overrideCreditLimit     Decimal?            @map("override_credit_limit") @db.Decimal(12, 2)
  overrideCreditTenure    Int?                @map("override_credit_tenure")
  overrideGracePeriod     Int?                @map("override_grace_period")
  overrideBlacklistDays   Int?                @map("override_blacklist_days")
  overrideInterestRate    Decimal?            @map("override_interest_rate") @db.Decimal(6, 3)
  overrideInterestFreqDays Int?               @map("override_interest_freq_days")
  overridePenaltyAmount   Decimal?            @map("override_penalty_amount") @db.Decimal(12, 2)
  overridePenaltyFreqDays Int?                @map("override_penalty_freq_days")

  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user                  User                @relation(fields: [userId], references: [id])
  vendor                Vendor?             @relation(fields: [vendorId], references: [id])
  transactions          CreditWalletTxn[]
  repayments            CreditWalletRepayment[]
  penalties             CreditWalletPenalty[]
  auditLogs             CreditWalletAuditLog[]

  @@index([userId])
  @@index([vendorId])
  @@index([status, currentDueDate])
  @@map("credit_wallets")
}

model CreditWalletTxn {
  id               String              @id @default(uuid()) @db.Uuid
  walletId         String              @map("wallet_id") @db.Uuid
  type             CreditWalletTxnType
  amount           Decimal             @db.Decimal(12, 2)
  balanceAfterTxn  Decimal             @map("balance_after_txn") @db.Decimal(12, 2)
  referenceId      String?             @map("reference_id")
  note             String?             @db.Text
  createdAt        DateTime            @default(now()) @map("created_at") @db.Timestamptz

  wallet           CreditWallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("credit_wallet_transactions")
}

model CreditWalletRepayment {
  id                 String       @id @default(uuid()) @db.Uuid
  walletId           String       @map("wallet_id") @db.Uuid
  amount             Decimal      @db.Decimal(12, 2)
  repaymentMethod    String       @map("repayment_method")
  razorpayOrderId    String?      @map("razorpay_order_id")
  // DB-level idempotency: a captured payment can be applied at most once.
  razorpayPaymentId  String?      @unique @map("razorpay_payment_id")
  status             String       @default("PENDING")
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz

  wallet             CreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([razorpayOrderId])
  @@map("credit_wallet_repayments")
}

model CreditWalletPenalty {
  id            String            @id @default(uuid()) @db.Uuid
  walletId      String            @map("wallet_id") @db.Uuid
  type          CreditPenaltyType
  amount        Decimal           @db.Decimal(12, 2)
  appliedDate   DateTime          @map("applied_date") @db.Date
  status        String            @default("APPLIED")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz

  wallet        CreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // Per-day idempotency: one INTEREST and one LATE_FEE row per wallet per day max,
  // so a re-run of the daily scheduler can't double-charge.
  @@unique([walletId, type, appliedDate])
  @@index([walletId])
  @@map("credit_wallet_penalties")
}

model CreditWalletAuditLog {
  id                 String       @id @default(uuid()) @db.Uuid
  walletId           String       @map("wallet_id") @db.Uuid
  action             String
  performedBy        String       @map("performed_by")
  previousValue      String?      @map("previous_value") @db.Text
  newValue           String?      @map("new_value") @db.Text
  remarks            String?      @db.Text
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz

  wallet             CreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("credit_wallet_audit_logs")
}


// ═══ NOTIFICATIONS ══════════════════════════════════

model Notification {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  type          String             @db.VarChar(30)
  channel       NotificationChannel
  title         String?            @db.VarChar(255)
  body          String?            @db.Text
  referenceId   String?            @map("reference_id") @db.Uuid
  referenceType String?            @map("reference_type") @db.VarChar(30)
  status        NotificationStatus @default(pending)
  readAt        DateTime?          @map("read_at") @db.Timestamptz
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("notifications")
}

enum NotificationChannel {
  sms
  email
  whatsapp
  push
  in_app
}

enum NotificationStatus {
  pending
  sent
  failed
}

// ═══════════════════════════════════════════════════════
//  BRAND STORE — Phase 1
// ═══════════════════════════════════════════════════════

// The brand company entity (e.g. "Kissan", "Everest")
model Brand {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  // V2.2: Brand is a 1:1 extension of BusinessAccount (isBrand=true). NOT NULL after Step C.
  businessAccountId String       @unique @map("business_account_id") @db.Uuid
  name            String         @unique @db.VarChar(255)
  slug            String         @unique @db.VarChar(255)
  description     String?        @db.Text
  logoUrl         String?        @map("logo_url") @db.VarChar(512)
  bannerUrl       String?        @map("banner_url") @db.VarChar(512)
  website         String?        @db.VarChar(512)
  tagline         String?        @db.VarChar(512)
  categories      String[]       @default([]) @map("categories")
  bgColor         String?        @map("bg_color") @db.VarChar(20)
  showcaseImages  String[]       @default([]) @map("showcase_images")
  // Profile Mastersheet — Tier A onboarding (CSV rows 22–29, attribute master 84–93).
  // `categories` holds Product Categories from the mastersheet.
  brandType             String?  @map("brand_type") @db.VarChar(80)
  subType               String?  @map("sub_type") @db.VarChar(80)
  businessSize          String?  @map("business_size") @db.VarChar(50)
  distributionPresence  String?  @map("distribution_presence") @db.VarChar(120)
  targetSegments        String[] @default([]) @map("target_segments")
  horecaFocused         Boolean? @map("horeca_focused")
  retailFocused         Boolean? @map("retail_focused")
  // Tier B — admin-only after onboarding
  brandTier             String?  @map("brand_tier") @db.VarChar(50)
  marketplaceVisibility String?  @map("marketplace_visibility") @db.VarChar(50)
  creditSupport         Boolean? @map("credit_support")
  leadStatus            String?  @map("lead_status") @db.VarChar(50)
  approvalStatus  ApprovalStatus @default(pending) @map("approval_status")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user            User                  @relation(fields: [userId], references: [id])
  businessAccount BusinessAccount       @relation(fields: [businessAccountId], references: [id])
  masterProducts  BrandMasterProduct[]
  productMappings BrandProductMapping[]
  teamMembers     BrandTeamMember[]
  distributorInvites BrandDistributorInvite[]
  // V2.2 Phase 4 — pricelists assigned to this brand
  priceListAssignments PriceListAssignment[] @relation("PriceListAssignmentBrand")

  @@index([slug])
  @@index([approvalStatus])
  @@index([userId])
  @@map("brands")
}

// Brand-submitted distributor leads — Phase 2.
// Brand owners fill a form to introduce a candidate distributor; admin team
// reviews and onboards manually. Once onboarded, link `vendorId` for traceability.
model BrandDistributorInvite {
  id            String                       @id @default(uuid()) @db.Uuid
  brandId       String                       @map("brand_id") @db.Uuid
  contactName   String                       @map("contact_name") @db.VarChar(255)
  email         String                       @db.VarChar(255)
  phone         String?                      @db.VarChar(30)
  businessName  String                       @map("business_name") @db.VarChar(255)
  city          String?                      @db.VarChar(100)
  pincode       String?                      @db.VarChar(10)
  notes         String?                      @db.Text
  status        BrandDistributorInviteStatus @default(pending)
  vendorId      String?                      @map("vendor_id") @db.Uuid // populated once admin onboards
  reviewedBy    String?                      @map("reviewed_by") @db.Uuid
  reviewNote    String?                      @map("review_note") @db.Text
  createdAt     DateTime                     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  brand Brand @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([status])
  @@map("brand_distributor_invites")
}

enum BrandDistributorInviteStatus {
  pending
  contacted
  onboarded
  declined
}

// Brand's canonical product catalog (the truth layer — no pricing)
model BrandMasterProduct {
  id              String   @id @default(uuid()) @db.Uuid
  brandId         String   @map("brand_id") @db.Uuid
  masterProductId String?  @map("master_product_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid               // primary (legacy single-category display)
  categoryIds     String[] @default([]) @map("category_ids") @db.Uuid  // all categories this product belongs to
  name            String  @db.VarChar(255)          // canonical name e.g. "Kissan Tomato Ketchup 1kg"
  slug            String  @db.VarChar(255)          // url-safe slug derived from name
  description     String? @db.Text
  imageUrl        String? @map("image_url") @db.VarChar(512)
  packSize        String? @map("pack_size") @db.VarChar(100)
  unit            String? @db.VarChar(50)
  sku             String? @db.VarChar(100)          // mirrors MasterProduct.sku when linked
  category        String? @db.VarChar(100)          // display category label
  isActive        Boolean @default(true) @map("is_active")
  sortOrder       Int     @default(0) @map("sort_order")
  // Embedding for AI-assisted brand mapping (Phase 3).
  embedding          Float[]   @default([]) @map("embedding")
  embeddingModel     String?   @map("embedding_model") @db.VarChar(80)
  embeddingUpdatedAt DateTime? @map("embedding_updated_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  brand         Brand             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  masterProduct MasterProduct?    @relation(fields: [masterProductId], references: [id], onDelete: SetNull)
  categoryRel   Category?         @relation(fields: [categoryId], references: [id])
  mappings      BrandProductMapping[]

  @@unique([brandId, slug])
  @@index([brandId])
  @@index([categoryId])
  @@index([masterProductId])
  @@map("brand_master_products")
}

// Bridge: BrandMasterProduct ↔ Distributor Product (auto-detected or manually verified)
model BrandProductMapping {
  id                   String        @id @default(uuid()) @db.Uuid
  brandId              String        @map("brand_id") @db.Uuid
  brandMasterProductId String        @map("brand_master_product_id") @db.Uuid
  distributorProductId String        @map("distributor_product_id") @db.Uuid
  confidenceScore      Decimal       @default(0) @map("confidence_score") @db.Decimal(4, 3) // 0.000–1.000
  status               MappingStatus @default(pending_review) @map("status")
  matchedBy            MatchMethod   @map("matched_by")
  reviewedBy           String?       @map("reviewed_by") @db.Uuid
  reviewNote           String?       @map("review_note") @db.Text
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  brand               Brand               @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandMasterProduct  BrandMasterProduct  @relation(fields: [brandMasterProductId], references: [id], onDelete: Cascade)
  distributorProduct  Product             @relation(fields: [distributorProductId], references: [id], onDelete: Cascade)

  @@unique([brandMasterProductId, distributorProductId])
  @@index([brandId])
  @@index([status])
  @@map("brand_product_mappings")
}

enum MappingStatus {
  auto_mapped
  pending_review
  verified
  rejected
}

enum MatchMethod {
  rule_based
  manually_verified
}

// ═══ TEAM MEMBERS (per-entity sub-accounts with scoped permissions) ═══

model VendorTeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
