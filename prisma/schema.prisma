}

// ═══ CREDIT (DiSCCO) ════════════════════════════════

model CreditAccount {
  id                  String       @id @default(uuid()) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  vendorId            String       @map("vendor_id") @db.Uuid
  creditLimit         Decimal      @default(0) @map("credit_limit") @db.Decimal(12, 2)
  creditUsed          Decimal      @default(0) @map("credit_used") @db.Decimal(12, 2)
  status              CreditStatus @default(pending)
  graceDays           Int          @default(0) @map("grace_days")
  interestRatePct     Decimal      @default(0) @map("interest_rate_pct") @db.Decimal(5, 2)
  penaltyRatePct      Decimal      @default(0) @map("penalty_rate_pct") @db.Decimal(5, 2)
  freezeOnOverdueDays Int          @default(0) @map("freeze_on_overdue_days")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz
