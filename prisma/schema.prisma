// ═══ SAVED ADDRESSES ══════════════════════════════════

model SavedAddress {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  // V2.2: each SavedAddress now also exists as an Outlet under the user's primary BusinessAccount.
  // Legacy table preserved for back-compat; new code uses Outlet directly.
  outletId     String?  @map("outlet_id") @db.Uuid
  label        String   @default("Other") @db.VarChar(50)
  businessName String?  @map("business_name") @db.VarChar(255)
  fullAddress  String   @map("full_address") @db.Text
  shortAddress String?  @map("short_address") @db.VarChar(255)
  flatInfo     String?  @map("flat_info") @db.VarChar(255)
  landmark     String?  @db.VarChar(255)
  pincode      String?  @db.VarChar(10)
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  latitude     Float
  longitude    Float
  placeId      String?  @map("place_id") @db.VarChar(500)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outlet       Outlet?  @relation(fields: [outletId], references: [id])

  @@index([userId])
  @@index([outletId])
  @@map("saved_addresses")
}

// AuditLog — append-only log of admin / privileged mutations.
// WHY: Compliance + forensics. When an approval, price edit, or RBAC change
// happens, we need to know who did it, when, and what changed. No FKs so a
// deleted actor/entity doesn't void the record.
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @map("actor_id") @db.Uuid
  actorRole String?  @map("actor_role") @db.VarChar(50)
  action    String   @db.VarChar(100)
  entity    String   @db.VarChar(100)
  entityId  String?  @map("entity_id") @db.VarChar(255)
  before    Json?
  after     Json?
  metadata  Json?
  ip        String?  @db.VarChar(64)
  at        DateTime @default(now()) @db.Timestamptz

  @@index([actorId, at])
  @@index([entity, entityId])
  @@index([at])
  @@map("audit_logs")
}

model ReturnRequest {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  reason            String   @db.Text
  status            String   @default("pending") @db.VarChar(20)
  adminNote         String?  @map("admin_note") @db.Text
  refundAmount      Decimal? @map("refund_amount") @db.Decimal(12, 2)
  resolutionType    String?  @map("resolution_type") @db.VarChar(20)
  creditNoteNumber  String?  @map("credit_note_number") @db.VarChar(50)
  creditNoteAmount  Decimal? @map("credit_note_amount") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  order    Order @relation(fields: [orderId], references: [id])
  customer User  @relation("CustomerReturnRequests", fields: [customerId], references: [id])

  @@unique([orderId])
  @@index([status])
  @@map("return_requests")
}

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
  @@map("push_subscriptions")
}

model VendorDocument {
  id         String   @id @default(uuid()) @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  type       String   @db.VarChar(50)
  fileUrl    String   @map("file_url") @db.VarChar(512)
  fileName   String   @map("file_name") @db.VarChar(255)
  status     String   @default("pending") @db.VarChar(20)
  adminNote  String?  @map("admin_note") @db.Text
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@map("vendor_documents")
}

// ═══ WEBHOOK EVENTS (idempotency) ═════════════════════
//
// Razorpay (and any future provider) can replay webhooks if our 200 ack is
// delayed. Insert-on-arrival into a unique index is the simplest dedup —
// duplicate event_ids fail the insert and we ack without re-running the work.

model WebhookEvent {
  id              String   @id @default(uuid()) @db.Uuid
  provider        String   @db.VarChar(20)            // 'razorpay' | future
  providerEventId String   @map("provider_event_id") @db.VarChar(100)
  event           String   @db.VarChar(60)            // e.g. 'payment.captured'
  receivedAt      DateTime @default(now()) @map("received_at") @db.Timestamptz

  @@unique([provider, providerEventId])
  @@index([event])
  @@map("webhook_events")
}

// ═══ OTP CODES ════════════════════════════════════════

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(320)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone])
  @@index([email])
  @@map("otp_codes")
}

// ═══════════════════════════════════════════════════════
//  V2.2 — MULTI-ACCOUNT (HCID) & RBAC ARCHITECTURE
//  See docs/multi-account-rbac-implementation-plan.md
// ═══════════════════════════════════════════════════════

enum BusinessAccountStatus {
  active
  suspended
  deactivated
}

enum RoleScope {
  account
  vendor
  brand
  admin
  delivery
}

// Top-level tenancy entity. A single User (HCID) can belong to many BusinessAccounts.
// `isCustomer`/`isVendor`/`isBrand` flags let one account play multiple roles.
model BusinessAccount {
  id              String   @id @default(uuid()) @db.Uuid
  legalName       String   @map("legal_name") @db.VarChar(255)
  displayName     String?  @map("display_name") @db.VarChar(255)
  gstin           String?  @db.VarChar(20)
  pan             String?  @db.VarChar(20)
  fssaiNumber     String?  @map("fssai_number") @db.VarChar(50)
  billingAddressLine String? @map("billing_address_line") @db.Text
  billingCity     String?  @map("billing_city") @db.VarChar(100)
  billingState    String?  @map("billing_state") @db.VarChar(100)
  billingPincode  String?  @map("billing_pincode") @db.VarChar(10)
  businessType    String?  @map("business_type") @db.VarChar(50)
  // Customer master-datasheet attributes (Profile Mastersheet). Free-text/nullable
  // so they can be set via signup, admin edit, or bulk import. Filterable in admin.
  subType             String?  @map("sub_type") @db.VarChar(80)
  cuisine             String?  @map("cuisine") @db.VarChar(120)
  businessSize        String?  @map("business_size") @db.VarChar(50)
  businessStructure   String?  @map("business_structure") @db.VarChar(50)
  serviceModel        String?  @map("service_model") @db.VarChar(120)
  monthlyPurchaseBand String?  @map("monthly_purchase_band") @db.VarChar(50)
  procurementFrequency String? @map("procurement_frequency") @db.VarChar(50)
  designation         String?  @map("designation") @db.VarChar(120)
  leadStatus          String?  @map("lead_status") @db.VarChar(50)
  creditType          String?  @map("credit_type") @db.VarChar(50)
  manualTags          String[] @default([]) @map("manual_tags")
  aiTags              String[] @default([]) @map("ai_tags")
  behaviourTags       String[] @default([]) @map("behaviour_tags")
  // Zoho-style customer/vendor parity fields (V2.2). Most are free-text/nullable
  // so they can be set on create, admin edit, or bulk import.
  customerType        String   @default("business") @map("customer_type") @db.VarChar(20) // business | individual
  salutation          String?  @db.VarChar(20)
  firstName           String?  @map("first_name") @db.VarChar(120)
  lastName            String?  @map("last_name") @db.VarChar(120)
  companyName         String?  @map("company_name") @db.VarChar(255)
  customerLanguage    String   @default("en") @map("customer_language") @db.VarChar(20)
  taxPreference       String   @default("taxable") @map("tax_preference") @db.VarChar(20) // taxable | exempt
  gstTreatment        String?  @map("gst_treatment") @db.VarChar(40)
  placeOfSupply       String?  @map("place_of_supply") @db.VarChar(100)
  currency            String   @default("INR") @db.VarChar(10)
  creditLimit         Decimal? @map("credit_limit") @db.Decimal(12, 2)
  paymentTerms        String?  @map("payment_terms") @db.VarChar(40)
  enablePortal        Boolean  @default(false) @map("enable_portal")
  workPhone           String?  @map("work_phone") @db.VarChar(20)
  mobilePhone         String?  @map("mobile_phone") @db.VarChar(20)
  remarks             String?  @db.Text
  customFields        Json     @default("{}") @map("custom_fields")
  isCustomer      Boolean  @default(true)  @map("is_customer")
  isVendor        Boolean  @default(false) @map("is_vendor")
  isBrand         Boolean  @default(false) @map("is_brand")
  status          BusinessAccountStatus @default(active)
  primaryOutletId String?  @unique @map("primary_outlet_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  members         BusinessAccountMember[]
  outlets         Outlet[]
  contactPersons  ContactPerson[]
  roles           AccountRole[]
  userRoles       UserRole[]
  vendor          Vendor?
  brand           Brand?
  orders          Order[]
  carts           Cart[]
  quickOrderLists QuickOrderList[]
  customerVendors CustomerVendor[]
  // V2.2 Phase 4 — pricelists assigned to this BA
  priceListAssignments PriceListAssignment[] @relation("PriceListAssignmentBA")

  @@index([isVendor])
  @@index([isBrand])
  @@map("business_accounts")
}

// HCID ↔ BusinessAccount mapping. Replaces LinkedAccount.
model BusinessAccountMember {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  businessAccountId String    @map("business_account_id") @db.Uuid
  isPrimary         Boolean   @default(false) @map("is_primary")
  invitedBy         String?   @map("invited_by") @db.Uuid
  acceptedAt        DateTime? @map("accepted_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user            User            @relation("UserAccountMembership", fields: [userId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  inviter         User?           @relation("AccountInvites", fields: [invitedBy], references: [id])

  @@unique([userId, businessAccountId])
  @@index([userId])
  @@index([businessAccountId])
  @@map("business_account_members")
}

// Physical location belonging to a BusinessAccount.
// Outlet OWNS its address (line, city, pincode, lat/lng).
// `latitude`/`longitude` are nullable for synthetic outlets pending address backfill.
model Outlet {
  id                    String   @id @default(uuid()) @db.Uuid
  businessAccountId     String   @map("business_account_id") @db.Uuid
  name                  String   @db.VarChar(255)
  code                  String?  @db.VarChar(50)
  addressLine           String   @map("address_line") @db.Text
  flatInfo              String?  @map("flat_info") @db.VarChar(255)
  landmark              String?  @db.VarChar(255)
  city                  String?  @db.VarChar(100)
  state                 String?  @db.VarChar(100)
  pincode               String?  @db.VarChar(10)
  latitude              Float?
  longitude             Float?
  placeId               String?  @map("place_id") @db.VarChar(500)
  isActive              Boolean  @default(true) @map("is_active")
  requiresAddressUpdate Boolean  @default(false) @map("requires_address_update")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  orders          Order[]
  carts           Cart[]
  userRoles       UserRole[]
  savedAddresses  SavedAddress[]
  // V2.2 Phase 4 — pricelists assigned to this outlet
  priceListAssignments PriceListAssignment[] @relation("PriceListAssignmentOutlet")

  @@index([businessAccountId])
  @@index([pincode])
  @@map("outlets")
}

// Zoho-style "Contact Persons" — multiple named contacts per BusinessAccount
// (beyond the single owner User). Used by the customer/vendor profile form.
model ContactPerson {
  id                String   @id @default(uuid()) @db.Uuid
  businessAccountId String   @map("business_account_id") @db.Uuid
  salutation        String?  @db.VarChar(20)
  firstName         String?  @map("first_name") @db.VarChar(120)
  lastName          String?  @map("last_name") @db.VarChar(120)
  email             String?  @db.VarChar(255)
  workPhone         String?  @map("work_phone") @db.VarChar(20)
  mobile            String?  @db.VarChar(20)
  designation       String?  @db.VarChar(120)
  isPrimary         Boolean  @default(false) @map("is_primary")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  businessAccount   BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)

  @@index([businessAccountId])
  @@map("contact_persons")
}

// RBAC role: per-account JSON permissions matrix.
// `businessAccountId = null` + `isTemplate = true` => seeded system template.
// Named AccountRole (not Role) to avoid colliding with the existing `Role` enum (customer/vendor/admin/brand).
model AccountRole {
  id                String    @id @default(uuid()) @db.Uuid
  businessAccountId String?   @map("business_account_id") @db.Uuid
  name              String    @db.VarChar(100)
  description       String?   @db.Text
  permissions       Json
  isTemplate        Boolean   @default(false) @map("is_template")
  scope             RoleScope @default(account)
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  businessAccount    BusinessAccount?    @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  userRoles          UserRole[]
  vendorTeamMembers  VendorTeamMember[]  @relation("VendorTeamMemberRole")
  brandTeamMembers   BrandTeamMember[]   @relation("BrandTeamMemberRole")
  adminTeamMembers   AdminTeamMember[]   @relation("AdminTeamMemberRole")

  @@unique([businessAccountId, name])
  @@index([isTemplate, scope])
  @@map("account_roles")
}

// User ↔ Role assignment, optionally narrowed to one Outlet (outletId = null => all outlets in account).
// Permissions from multiple UserRole rows are UNION-merged at request time.
model UserRole {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  businessAccountId String   @map("business_account_id") @db.Uuid
  outletId          String?  @map("outlet_id") @db.Uuid
  roleId            String   @map("role_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user            User            @relation("UserRoles", fields: [userId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  outlet          Outlet?         @relation(fields: [outletId], references: [id], onDelete: Cascade)
  role            AccountRole     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, businessAccountId, outletId, roleId])
  @@index([userId])
  @@index([businessAccountId])
  @@map("user_roles")
}

// ═══ VENDOR WALLET & SETTLEMENT ══════════════════════

model VendorWallet {
  id            String   @id @default(uuid()) @db.Uuid
  vendorId      String   @unique @map("vendor_id") @db.Uuid
  balance       Decimal  @default(0) @db.Decimal(12, 2)
  pendingAmount Decimal  @default(0) @map("pending_amount") @db.Decimal(12, 2)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor       Vendor             @relation(fields: [vendorId], references: [id])
  transactions VendorWalletTxn[]
  settlements  VendorSettlement[]

  @@map("vendor_wallets")
}

model VendorWalletTxn {
  id            String              @id @default(uuid()) @db.Uuid
  walletId      String              @map("wallet_id") @db.Uuid
  type          VendorWalletTxnType
  amount        Decimal             @db.Decimal(12, 2)
  balanceAfter  Decimal             @map("balance_after") @db.Decimal(12, 2)
  referenceId   String?             @map("reference_id") @db.Uuid
  referenceType String?             @map("reference_type") @db.VarChar(30)
  notes         String?             @db.Text
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz

  wallet VendorWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("vendor_wallet_txns")
}

enum VendorWalletTxnType {
  order_credit
  settlement_debit
  adjustment
  refund_debit
}

model VendorSettlement {
  id            String           @id @default(uuid()) @db.Uuid
  vendorId      String           @map("vendor_id") @db.Uuid
  walletId      String           @map("wallet_id") @db.Uuid
  grossAmount   Decimal          @map("gross_amount") @db.Decimal(12, 2)
  platformFee   Decimal          @default(0) @map("platform_fee") @db.Decimal(12, 2)
  gatewayFee    Decimal          @default(0) @map("gateway_fee") @db.Decimal(12, 2)
  netAmount     Decimal          @map("net_amount") @db.Decimal(12, 2)
  status        SettlementStatus @default(pending)
  bankReference String?          @map("bank_reference") @db.VarChar(100)
  periodStart   DateTime         @map("period_start") @db.Date
  periodEnd     DateTime         @map("period_end") @db.Date
  settledAt     DateTime?        @map("settled_at") @db.Timestamptz
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor  Vendor                  @relation(fields: [vendorId], references: [id])
  wallet  VendorWallet            @relation(fields: [walletId], references: [id])
  orders  VendorSettlementOrder[]

  @@index([vendorId])
  @@index([status])
  @@map("vendor_settlements")
}

enum SettlementStatus {
  pending
  processing
  settled
  failed
}

model VendorSettlementOrder {
  id           String   @id @default(uuid()) @db.Uuid
  settlementId String   @map("settlement_id") @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  orderAmount  Decimal  @map("order_amount") @db.Decimal(12, 2)
  platformFee  Decimal  @default(0) @map("platform_fee") @db.Decimal(12, 2)
  netAmount    Decimal  @map("net_amount") @db.Decimal(12, 2)

  settlement VendorSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@unique([settlementId, orderId])
  @@index([settlementId])
  @@map("vendor_settlement_orders")
}

// ═══ VENDOR CUSTOMER MAPPING ═════════════════════════

model VendorCustomer {
  id           String               @id @default(uuid()) @db.Uuid
  vendorId     String               @map("vendor_id") @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  status       VendorCustomerStatus @default(active)
  priceListId  String?              @map("price_list_id") @db.Uuid
  territory       String?              @db.VarChar(100)
  // Legacy free-text salesperson name. Preserved for one release cycle so
  // bulk-import scripts still parse old files; new code reads salespersonId
  // first and falls back to this string only when the FK is null.
  salesExecutive  String?              @map("sales_executive") @db.VarChar(100)
  salespersonId   String?              @map("salesperson_id") @db.Uuid
  deliveryRoute   String?              @map("delivery_route") @db.VarChar(100)
  tags            String[]             @default([]) @map("tags")
  notes           String?              @db.Text
  paymentTerms    String?              @map("payment_terms") @db.VarChar(50)
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor       @relation("VendorCustomerMapping", fields: [vendorId], references: [id], onDelete: Cascade)
  user        User         @relation("VendorCustomerUser", fields: [userId], references: [id])
  priceList   PriceList?   @relation(fields: [priceListId], references: [id])
  salesperson Salesperson? @relation(fields: [salespersonId], references: [id], onDelete: SetNull)

  @@unique([vendorId, userId])
  @@index([vendorId])
  @@index([userId])
  @@index([salespersonId])
  @@map("vendor_customers")
}

model VendorCustomerTask {
  id         String    @id @default(uuid()) @db.Uuid
  vendorId   String    @map("vendor_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  title      String    @db.VarChar(255)
  notes      String?   @db.Text
  dueDate    DateTime? @map("due_date") @db.Timestamptz
  isDone     Boolean   @default(false) @map("is_done")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, customerId])
  @@map("vendor_customer_tasks")
}

enum VendorCustomerStatus {
  active
  blocked
  suspended
}

// ═══ PRICE LISTS ═════════════════════════════════════

model PriceList {
  id              String   @id @default(uuid()) @db.Uuid
  vendorId        String   @map("vendor_id") @db.Uuid
  name            String   @db.VarChar(255)
  // Global fallback discount applied when no PriceListItem matches a
  // given product. Items override this per-product via customPrice or
  // their own discountPercent.
  discountPercent Decimal  @default(0) @map("discount_percent") @db.Decimal(5, 2)
  isActive        Boolean  @default(true) @map("is_active")
  // List-level validity window. When set, the resolver ignores this list
  // outside [validFrom, validTo] and the customer falls back to base/other.
  validFrom       DateTime? @map("valid_from") @db.Timestamptz
  validTo         DateTime? @map("valid_to") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items       PriceListItem[]
  customers   VendorCustomer[]
  assignments PriceListAssignment[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(uuid()) @db.Uuid
  priceListId String   @map("price_list_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  // customPrice is the resolved unit price for `fixed` / `special`, and
  // the post-threshold price for `scheme`. Nullable for `discount` rows
  // (where discountPercent is the source of truth) so the schema rejects
  // a half-built row that has neither.
  customPrice Decimal? @map("custom_price") @db.Decimal(10, 2)

  // V2.2 Phase 4 — pricing-type discriminator + per-type knobs.
  pricingType     PricingType @default(fixed) @map("pricing_type")
  discountPercent Decimal?    @map("discount_percent") @db.Decimal(5, 2)
  schemeMinQty    Int?        @map("scheme_min_qty")
  schemeFreeQty   Int?        @map("scheme_free_qty")

  // V2.2 Phase 5 — pricing cell attributes
  isLocked        Boolean   @default(false) @map("is_locked")
  validFrom       DateTime? @map("valid_from") @db.Timestamptz
  validTo         DateTime? @map("valid_to") @db.Timestamptz
  note            String?   @db.Text
  scheduledPrice  Decimal?  @map("scheduled_price") @db.Decimal(10, 2)
  scheduledFrom   DateTime? @map("scheduled_from") @db.Timestamptz
  scheduledTo     DateTime? @map("scheduled_to") @db.Timestamptz
  history         Json?     @default("[]")

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@map("price_list_items")
}

// V2.2 Phase 4 — Pricing model discriminator.
//   fixed    — customPrice replaces basePrice.
//   discount — basePrice × (1 − discountPercent/100).
//   special  — same math as fixed; UI flags it differently (badge).
//   scheme   — qty-gated: customPrice applies when quantity ≥ schemeMinQty.
enum PricingType {
  fixed
  discount
  special
  scheme

  @@map("pricing_type")
}

// V2.2 Phase 4 — Targeting rule for a PriceList. Exactly one of the
// targeting columns on PriceListAssignment should be populated per row;
// the column used is implied by `type`. The resolver picks the most-
// specific matching rule per the priority chain in pricing.service.ts.
enum PriceListAssignmentType {
  customer
  outlet
  pincode
  area
  segment
  brand
  group

  @@map("price_list_assignment_type")
}

model PriceListAssignment {
  id                String                  @id @default(uuid()) @db.Uuid
  priceListId       String                  @map("price_list_id") @db.Uuid
  type              PriceListAssignmentType
  // Targeting columns — service layer picks the right one based on `type`.
  // Cascade on the FK columns so when a User / Outlet / Brand / BA is
  // deleted, the orphaned assignments disappear too. Free-text columns
  // (pincode / area / segment / brandName) don't have a referential
  // target so they can't dangle.
  userId            String?                 @map("user_id") @db.Uuid
  businessAccountId String?                 @map("business_account_id") @db.Uuid
  outletId          String?                 @map("outlet_id") @db.Uuid
  brandId           String?                 @map("brand_id") @db.Uuid
  groupId           String?                 @map("group_id") @db.Uuid
  pincode           String?                 @db.VarChar(10)
  area              String?                 @db.VarChar(100)
  segment           String?                 @db.VarChar(100)
  brandName         String?                 @map("brand_name") @db.VarChar(150)
  // Audit: who wired this assignment and when (shown on the customer profile).
  assignedById      String?                 @map("assigned_by_id") @db.Uuid
  assignedAt        DateTime?               @map("assigned_at") @db.Timestamptz
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz

  priceList       PriceList        @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  user            User?            @relation("PriceListAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount? @relation("PriceListAssignmentBA", fields: [businessAccountId], references: [id], onDelete: Cascade)
  outlet          Outlet?          @relation("PriceListAssignmentOutlet", fields: [outletId], references: [id], onDelete: Cascade)
  brand           Brand?           @relation("PriceListAssignmentBrand", fields: [brandId], references: [id], onDelete: Cascade)
  group           CustomerGroup?   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([priceListId, type])
  @@index([userId])
  @@index([businessAccountId])
  @@index([outletId])
  @@index([pincode])
  @@index([brandId])
  @@index([groupId])
  @@map("price_list_assignments")
}

// Named groups of customers a vendor can target with a price list (spec:
// "Customer Group"). Membership is by user or business account.
model CustomerGroup {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  members     CustomerGroupMember[]
  assignments PriceListAssignment[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@map("customer_groups")
}

model CustomerGroupMember {
  id                String   @id @default(uuid()) @db.Uuid
  groupId           String   @map("group_id") @db.Uuid
  // One of these identifies the member; resolver matches either.
  userId            String?  @map("user_id") @db.Uuid
  businessAccountId String?  @map("business_account_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  group CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@map("customer_group_members")
}

// ═══ PROMOTIONS ═══════════════════════════════════════

model Promotion {
  id          String        @id @default(uuid()) @db.Uuid
  vendorId    String        @map("vendor_id") @db.Uuid
  name        String        @db.VarChar(120)
  type        PromotionType
  isActive    Boolean       @default(true) @map("is_active")
  startDate   DateTime?     @map("start_date") @db.Timestamptz
  endDate     DateTime?     @map("end_date") @db.Timestamptz

  // Conditions
  minOrderValue Decimal? @map("min_order_value") @db.Decimal(10, 2)
  minQty        Int?     @map("min_qty")
  buyProductId  String?  @map("buy_product_id") @db.Uuid

  // Rewards
  discountPct  Decimal? @map("discount_pct") @db.Decimal(5, 2)
  discountFlat Decimal? @map("discount_flat") @db.Decimal(10, 2)
  getProductId String?  @map("get_product_id") @db.Uuid
  getQty       Int?     @map("get_qty")

  usageLimit Int? @map("usage_limit")
  usageCount Int  @default(0) @map("usage_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor     Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  buyProduct Product? @relation("PromoBuyProduct", fields: [buyProductId], references: [id])
  getProduct Product? @relation("PromoGetProduct", fields: [getProductId], references: [id])
  orders     Order[]

  @@index([vendorId, isActive])
  @@map("promotions")
}

enum PromotionType {
  pct_discount
  flat_discount
  bxgy

  @@map("promotion_type")
}

model VendorCustomerPrice {
  id          String   @id @default(uuid()) @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  customerId  String   @map("customer_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([vendorId, customerId, productId])
  @@map("vendor_customer_prices")
}

enum VegType {
  veg
  nonveg
  egg

  @@map("veg_type")
}

// Audit trail for inventory quantity changes
model InventoryLog {
  id          String   @id @default(uuid()) @db.Uuid
  inventoryId String   @map("inventory_id") @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  field       String   @db.VarChar(30)
  oldValue    Int
  newValue    Int
  reason      String?  @db.VarChar(200)
  changedBy   String?  @map("changed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([inventoryId])
  @@index([vendorId])
  @@map("inventory_logs")
}

// ─── Phase 1: Salesman Commission (V2.2) ──────────────────────────────────
// Structure-only build — accruals are auto-generated on order.delivered but
// no automated payout pipeline runs. Vendor + admin can view + approve +
// manually mark-paid; actual money movement is handled offline today.

// A vendor's sales representative. May or may not log into the platform —
// most distributor field-officers don't. Linking to a User is optional and
// only used when commissioning sales taken via a logged-in rep.
model Salesperson {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  name      String   @db.VarChar(255)
  phone     String?  @db.VarChar(15)
  email     String?  @db.VarChar(255)
  code      String?  @db.VarChar(30)  // vendor's internal employee id
  userId    String?  @map("user_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor          Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user            User?               @relation("UserSalespersonProfile", fields: [userId], references: [id], onDelete: SetNull)
  rules           CommissionRule[]
  accruals        CommissionAccrual[]
  vendorCustomers VendorCustomer[]
  orders          Order[]

  @@unique([vendorId, code])
  @@index([vendorId])
  @@index([userId])
  @@map("salespersons")
}

// Defines what a salesperson earns. Multiple rules allowed; resolution
// picks the most-specific active rule at the time the order is delivered:
//   customer-scoped > brand-scoped > category-scoped > default.
model CommissionRule {
  id            String              @id @default(uuid()) @db.Uuid
  vendorId      String              @map("vendor_id") @db.Uuid
  salespersonId String              @map("salesperson_id") @db.Uuid
  scope         CommissionRuleScope
  // When scope='customer'|'brand'|'category', this points at the
  // VendorCustomer.id, Brand.id, or Category.id the rule applies to.
  // Null for scope='default'. We don't FK this (the referenced model
  // varies by scope) — the service layer validates referential integrity.
  scopeRefId    String?             @map("scope_ref_id") @db.Uuid
  ratePercent   Decimal?            @map("rate_percent") @db.Decimal(5, 2)
  rateFixed     Decimal?            @map("rate_fixed") @db.Decimal(12, 2)
  minOrderValue Decimal?            @map("min_order_value") @db.Decimal(12, 2)
  validFrom     DateTime?           @map("valid_from") @db.Timestamptz
  validTo       DateTime?           @map("valid_to") @db.Timestamptz
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  salesperson Salesperson         @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  accruals    CommissionAccrual[]

  @@index([vendorId, salespersonId, isActive])
  @@index([scope, scopeRefId])
  @@map("commission_rules")
}

enum CommissionRuleScope {
  default
  customer
  brand
  category

  @@map("commission_rule_scope")
}

// One row per (Order, Salesperson). Generated when the order moves to
// 'delivered' state — see commission.service.ts. Append-only; status
// transitions in place. The unique constraint stops double-write if the
// status hook fires twice (idempotent).
model CommissionAccrual {
  id            String                  @id @default(uuid()) @db.Uuid
  orderId       String                  @map("order_id") @db.Uuid
  vendorId      String                  @map("vendor_id") @db.Uuid
  salespersonId String                  @map("salesperson_id") @db.Uuid
  ruleId        String?                 @map("rule_id") @db.Uuid
  baseAmount    Decimal                 @map("base_amount") @db.Decimal(12, 2)
  ratePercent   Decimal?                @map("rate_percent") @db.Decimal(5, 2)
  rateFixed     Decimal?                @map("rate_fixed") @db.Decimal(12, 2)
  accruedAmount Decimal                 @map("accrued_amount") @db.Decimal(12, 2)
  period        String                  @db.VarChar(7)  // 'YYYY-MM'
  status        CommissionAccrualStatus @default(pending)
  approvedBy    String?                 @map("approved_by") @db.Uuid
  approvedAt    DateTime?               @map("approved_at") @db.Timestamptz
  paidAt        DateTime?               @map("paid_at") @db.Timestamptz
  notes         String?                 @db.Text
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz

  order       Order           @relation(fields: [orderId], references: [id])
  vendor      Vendor          @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  salesperson Salesperson     @relation(fields: [salespersonId], references: [id])
  rule        CommissionRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  approver    User?           @relation("CommissionApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@unique([orderId, salespersonId])
  @@index([vendorId, period, status])
  @@index([salespersonId, period])
  @@map("commission_accruals")
}

enum CommissionAccrualStatus {
  pending
  approved
  paid
  cancelled

  @@map("commission_accrual_status")
}

// ═══════════════════════════════════════════════════════
//  PROMO ENGINE — Phase 1 (Coupons + Cashback)
// ═══════════════════════════════════════════════════════
//
// Two priority promos per the Marketing & Sales brief:
//   • Coupon  — immediate discount at checkout (one coupon per order, Rule 1)
//   • Cashback — earned on delivery, paid to prepaid Wallet or user's UPI
//
// Ownership: vendorId NULL = platform promo (admin-created, platform-wide
// or scope-narrowed); vendorId set = vendor promo, valid only on that
// vendor's orders — enforced in promotion.service, never trusted from input.

enum PromoDiscountType {
  flat
  percentage

  @@map("promo_discount_type")
}

enum CouponRedemptionStatus {
  active
  reversed

  @@map("coupon_redemption_status")
}

enum CashbackDestination {
  wallet
  upi

  @@map("cashback_destination")
}

// pending   — order placed, waiting for delivery
// approved  — delivered, UPI payout awaiting claim/manual transfer
// credited  — paid into the prepaid Wallet (walletTxnId set)
// paid      — UPI transfer done by admin (paidReference = UTR)
// cancelled — order cancelled/returned or grant revoked
enum CashbackEntryStatus {
  pending
  approved
  credited
  paid
  cancelled

  @@map("cashback_entry_status")
}

enum CashbackEntrySource {
  order
  direct_grant

  @@map("cashback_entry_source")
}

model Coupon {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique @db.VarChar(40) // stored UPPERCASE; lookups normalise
  name        String  @db.VarChar(120)
  description String? @db.Text
  vendorId    String? @map("vendor_id") @db.Uuid // null = platform coupon

  discountType  PromoDiscountType @map("discount_type")
  discountValue Decimal           @map("discount_value") @db.Decimal(10, 2)
  maxDiscount   Decimal?          @map("max_discount") @db.Decimal(10, 2) // cap for percentage type
  minOrderValue Decimal?          @map("min_order_value") @db.Decimal(12, 2)

  startDate DateTime? @map("start_date") @db.Timestamptz
  endDate   DateTime? @map("end_date") @db.Timestamptz

  usageLimit   Int? @map("usage_limit") // total checkouts, across all users
  perUserLimit Int? @map("per_user_limit")
  usedCount    Int  @default(0) @map("used_count")

  // Optional scope narrowing — empty arrays mean "whole store" (vendor coupon)
  // or "whole platform" (platform coupon). Brand match is on Product.brand text.
  categoryIds String[] @default([]) @map("category_ids") @db.Uuid
  productIds  String[] @default([]) @map("product_ids") @db.Uuid
  brandNames  String[] @default([]) @map("brand_names")

  // Stacking (brief: per-promo "can be clubbed" checkboxes).
  // Rule 1 (one coupon per checkout) is hard-coded in the service.
  stacksWithVendorPromo Boolean @default(true) @map("stacks_with_vendor_promo")
  stacksWithCashback    Boolean @default(true) @map("stacks_with_cashback")

  isActive    Boolean @default(true) @map("is_active")
  createdById String? @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor      Vendor?            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]
  orders      Order[]

  @@index([vendorId, isActive])
  @@index([isActive, endDate])
  @@map("coupons")
}

// One row per ORDER touched by a coupon. A multi-vendor checkout creates
// several orders but counts as ONE use — rows share a checkoutGroupId and
// usage counting is per distinct group with ≥1 active row.
model CouponRedemption {
  id              String                 @id @default(uuid()) @db.Uuid
  couponId        String                 @map("coupon_id") @db.Uuid
  userId          String                 @map("user_id") @db.Uuid
  orderId         String                 @unique @map("order_id") @db.Uuid
  checkoutGroupId String                 @map("checkout_group_id") @db.Uuid
  amount          Decimal                @db.Decimal(10, 2)
  status          CouponRedemptionStatus @default(active)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, userId, status])
  @@index([checkoutGroupId])
  @@map("coupon_redemptions")
}

model CashbackCampaign {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(120)
  description String? @db.Text
  vendorId    String? @map("vendor_id") @db.Uuid // null = platform campaign

  cashbackType  PromoDiscountType @map("cashback_type")
  cashbackValue Decimal           @map("cashback_value") @db.Decimal(10, 2)
  maxCashback   Decimal?          @map("max_cashback") @db.Decimal(10, 2) // cap for percentage type
  minOrderValue Decimal?          @map("min_order_value") @db.Decimal(12, 2)

  destination CashbackDestination @default(wallet)

  startDate DateTime? @map("start_date") @db.Timestamptz
  endDate   DateTime? @map("end_date") @db.Timestamptz

  perUserLimit Int?     @map("per_user_limit") // max earns per user
  totalBudget  Decimal? @map("total_budget") @db.Decimal(12, 2) // hard spend cap
  usedAmount   Decimal  @default(0) @map("used_amount") @db.Decimal(12, 2)
  usedCount    Int      @default(0) @map("used_count")

  // Rule 2 (coupon + cashback) — per-campaign "can be clubbed" checkbox.
  // Rule 5 (single highest cashback source) is hard-coded in the service.
  stacksWithCoupon Boolean @default(true) @map("stacks_with_coupon")

  isActive    Boolean @default(true) @map("is_active")
  createdById String? @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  vendor  Vendor?         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  entries CashbackEntry[]

  @@index([vendorId, isActive])
  @@index([isActive, endDate])
  @@map("cashback_campaigns")
}

// A single earned (or granted) cashback. Order-linked entries are created at
// checkout in `pending` and settled on delivery; direct grants (admin "reward
// this user" flow) are created already-approved/credited with no order.
// Campaign terms are snapshotted so settlement survives campaign edits AND
// admin order modifications (amount is recomputed from the snapshot at delivery).
model CashbackEntry {
  id         String              @id @default(uuid()) @db.Uuid
  campaignId String?             @map("campaign_id") @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  orderId    String?             @unique @map("order_id") @db.Uuid
  vendorId   String?             @map("vendor_id") @db.Uuid // funding vendor, for reporting
  source     CashbackEntrySource @default(order)

  amount      Decimal             @db.Decimal(10, 2)
  destination CashbackDestination
  upiId       String?             @map("upi_id") @db.VarChar(100) // captured via claim flow
  status      CashbackEntryStatus @default(pending)

  // Campaign snapshot for recompute-at-delivery
  cashbackType  PromoDiscountType? @map("cashback_type")
  cashbackValue Decimal?           @map("cashback_value") @db.Decimal(10, 2)
  maxCashback   Decimal?           @map("max_cashback") @db.Decimal(10, 2)
  minOrderValue Decimal?           @map("min_order_value") @db.Decimal(12, 2)

  walletTxnId   String? @unique @map("wallet_txn_id") @db.Uuid // ledger link when credited
  paidReference String? @map("paid_reference") @db.VarChar(100) // UTR / payout ref for UPI
  notes         String? @db.Text
  createdById   String? @map("created_by_id") @db.Uuid // admin who granted (direct grants)

  creditedAt  DateTime? @map("credited_at") @db.Timestamptz
  paidAt      DateTime? @map("paid_at") @db.Timestamptz
  cancelledAt DateTime? @map("cancelled_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  campaign CashbackCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user     User              @relation(fields: [userId], references: [id])
  order    Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([campaignId])
  @@index([status, destination])
  @@map("cashback_entries")
}

// Global, single-row platform configuration edited from the admin Settings page.
model PlatformSetting {
  id                    String   @id @default(uuid()) @db.Uuid
  platformName          String   @default("HoReCa1") @map("platform_name") @db.VarChar(120)
  contactEmail          String?  @map("contact_email") @db.VarChar(255)
  supportPhone          String?  @map("support_phone") @db.VarChar(30)
  defaultCommissionPct  Decimal  @default(10) @map("default_commission_pct") @db.Decimal(5, 2)
  minOrderValue         Decimal  @default(500) @map("min_order_value") @db.Decimal(10, 2)
  freeDeliveryThreshold Decimal  @default(2000) @map("free_delivery_threshold") @db.Decimal(10, 2)
  emailNotifications    Boolean  @default(true) @map("email_notifications")
  smsNotifications      Boolean  @default(true) @map("sms_notifications")
  pushNotifications     Boolean  @default(false) @map("push_notifications")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("platform_settings")
}
