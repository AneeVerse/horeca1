{
  "info": {
    "name": "Horeca1 API v1",
    "description": "B2B Multi-Vendor Wholesale Marketplace API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "vendorId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "listId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"chef@hotel.com\",\"phone\":\"+919876543210\",\"password\":\"SecureP@ss1\",\"full_name\":\"Rajesh Kumar\",\"role\":\"customer\",\"pincode\":\"400001\",\"business_name\":\"Hotel Taj\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.data && res.data.session) pm.collectionVariables.set('token', res.data.session.access_token);"]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"chef@hotel.com\",\"password\":\"SecureP@ss1\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if(res.data && res.data.session) pm.collectionVariables.set('token', res.data.session.access_token);"]
            }
          }]
        },
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/otp/request",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\":\"+919876543210\"}" }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/otp/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"phone\":\"+919876543210\",\"otp\":\"123456\"}" }
          }
        }
      ]
    },
    {
      "name": "Vendors",
      "item": [
        {
          "name": "List Vendors by Pincode",
          "request": { "method": "GET", "url": "{{baseUrl}}/vendors?pincode=400001&sort=rating&order=desc&limit=20" }
        },
        {
          "name": "Vendor Store Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/vendors/{{vendorId}}" }
        },
        {
          "name": "Vendor Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/vendors/{{vendorId}}/products?limit=20" }
        },
        {
          "name": "My Vendors",
          "request": { "method": "GET", "url": "{{baseUrl}}/vendors/my-vendors" }
        },
        {
          "name": "Follow Vendor",
          "request": { "method": "POST", "url": "{{baseUrl}}/vendors/{{vendorId}}/follow" }
        }
      ]
    },
    {
      "name": "Catalog & Search",
      "item": [
        {
          "name": "Search Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/search?q=tomato+ketchup&pincode=400001&limit=20" }
        },
        {
          "name": "List Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Category Vendors",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories/{{categoryId}}/vendors?pincode=400001" }
        },
        {
          "name": "List Collections",
          "request": { "method": "GET", "url": "{{baseUrl}}/collections" }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "View Cart",
          "request": { "method": "GET", "url": "{{baseUrl}}/cart" }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/items",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"product_id\":\"{{productId}}\",\"vendor_id\":\"{{vendorId}}\",\"quantity\":3}" }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/cart/items/{{cartItemId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"quantity\":5}" }
          }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"payment_method\":\"razorpay\"}" }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create PO",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"vendor_orders\":[{\"vendor_id\":\"{{vendorId}}\",\"items\":[{\"product_id\":\"{{productId}}\",\"quantity\":5}]}],\"payment_method\":\"razorpay\"}" }
          }
        },
        {
          "name": "List Orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders?limit=20" }
        },
        {
          "name": "Reorder",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders/reorder/{{orderId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "Save Order as List",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders/{{orderId}}/save-as-list",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"list_name\":\"Weekly Dairy\"}" }
          }
        }
      ]
    },
    {
      "name": "Quick Order Lists",
      "item": [
        {
          "name": "Get All Lists",
          "request": { "method": "GET", "url": "{{baseUrl}}/lists" }
        },
        {
          "name": "Create List",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/lists",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\":\"Weekly Dairy\",\"vendor_id\":\"{{vendorId}}\",\"items\":[{\"product_id\":\"{{productId}}\",\"default_qty\":5}]}" }
          }
        },
        {
          "name": "Order from List",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/lists/{{listId}}/order",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"items\":[{\"product_id\":\"{{productId}}\",\"quantity\":5}]}" }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/initiate",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"order_id\":\"{{orderId}}\",\"method\":\"razorpay\"}" }
          }
        },
        {
          "name": "Verify Payment (Webhook)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"razorpay_order_id\":\"order_xxx\",\"razorpay_payment_id\":\"pay_xxx\",\"razorpay_signature\":\"sig...\"}" }
          }
        }
      ]
    },
    {
      "name": "Credit (DiSCCO)",
      "item": [
        {
          "name": "Check Credit",
          "request": { "method": "GET", "url": "{{baseUrl}}/credit/check?vendor_id={{vendorId}}" }
        },
        {
          "name": "Apply Credit",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/credit/apply",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"order_id\":\"{{orderId}}\",\"amount\":1600.00}" }
          }
        },
        {
          "name": "Signup for Credit",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/credit/signup",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"vendor_id\":\"{{vendorId}}\",\"requested_limit\":50000}" }
          }
        }
      ]
    },
    {
      "name": "Serviceability",
      "item": [
        {
          "name": "Check Pincode",
          "request": { "method": "GET", "url": "{{baseUrl}}/serviceability/check?pincode=400001" }
        }
      ]
    }
  ]
}
